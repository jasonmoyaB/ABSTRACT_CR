@model Abstract_CR.Models.RestriccionesUsuariosViewModel

@{
    ViewData["Title"] = "Restricciones de Usuarios";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 text-primary">Restricciones de Usuarios</h2>
            <p class="text-muted mb-0">Gestiona las restricciones alimentarias de tus usuarios.</p>
        </div>
    </div>

    <div class="row">
        <!-- Panel de usuarios -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm h-100 border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-users me-2"></i>Usuarios</h5>
                </div>
                
                <!-- Buscador de usuarios -->
                <div class="card-body border-bottom bg-light py-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0 ps-0" 
                               id="buscarUsuario" 
                               placeholder="Buscar por nombre o correo..." 
                               autocomplete="off">
                        <button class="btn btn-outline-secondary" type="button" id="limpiarBusqueda" style="display: none;">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <small class="text-muted d-block mt-2">
                        <span id="contadorUsuarios">@Model.Usuarios?.Count() ?? 0</span> usuario(s) encontrado(s)
                    </small>
                </div>
                
                <div class="card-body p-0" style="max-height: 600px; overflow-y: auto;">
                    @if (Model.Usuarios != null && Model.Usuarios.Any())
                    {
                        <div class="list-group list-group-flush" id="listaUsuarios">
                            @foreach (var usuario in Model.Usuarios)
                            {
                                var esSeleccionado = usuario.UsuarioId == Model.UsuarioSeleccionadoId;
                                <a class="list-group-item list-group-item-action usuario-item @(esSeleccionado ? "bg-light text-primary fw-semibold" : "text-dark")"
                                   href="@Url.Action("RestriccionesUsuarios", "Administracion", new { usuarioId = usuario.UsuarioId })"
                                   data-nombre="@usuario.NombreCompleto.ToLower()"
                                   data-correo="@usuario.CorreoElectronico.ToLower()">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold nombre-usuario">@usuario.NombreCompleto</div>
                                            <small class="text-muted correo-usuario">@usuario.CorreoElectronico</small>
                                        </div>
                                        @if (esSeleccionado)
                                        {
                                            <i class="fas fa-check-circle text-primary"></i>
                                        }
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="p-3 text-muted text-center">No hay usuarios disponibles.</div>
                    }
                    
                    <!-- Mensaje cuando no hay resultados -->
                    <div class="p-4 text-center text-muted d-none" id="sinResultados">
                        <i class="fas fa-search fa-2x mb-3 opacity-50"></i>
                        <p class="mb-0">No se encontraron usuarios que coincidan con tu búsqueda.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de restricciones -->
        <div class="col-lg-8">
            @if (Model.UsuarioSeleccionadoId != 0)
            {
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-ban me-2"></i>Restricciones del usuario seleccionado</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.Restricciones != null && Model.Restricciones.Any())
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var restriccion in Model.Restricciones)
                                {
                                    <li class="list-group-item d-flex align-items-center">
                                        <i class="fas fa-exclamation-triangle text-warning me-3"></i>
                                        <span>@restriccion.Descripcion</span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center text-muted py-4">
                                <i class="fas fa-check-circle fa-2x text-success mb-3"></i>
                                <p class="mb-0">Este usuario no tiene restricciones registradas.</p>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm text-center py-5">
                    <i class="fas fa-user-circle fa-3x text-primary mb-3"></i>
                    <p class="mb-0 text-muted">Selecciona un usuario para ver sus restricciones.</p>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .usuario-item {
        transition: all 0.2s ease;
    }
    
    .usuario-item:hover {
        background-color: #f8f9fa !important;
        transform: translateX(5px);
    }
    
    #buscarUsuario:focus {
        box-shadow: none;
        border-color: #0d6efd;
    }
    
    .input-group-text {
        border-right: none;
    }
    
    #buscarUsuario {
        border-left: none;
    }
    
    #buscarUsuario:focus + .input-group-text {
        border-color: #0d6efd;
    }
    
    .highlight {
        background-color: #fff3cd;
        font-weight: 600;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const inputBuscar = document.getElementById('buscarUsuario');
        const btnLimpiar = document.getElementById('limpiarBusqueda');
        const listaUsuarios = document.getElementById('listaUsuarios');
        const sinResultados = document.getElementById('sinResultados');
        const contadorUsuarios = document.getElementById('contadorUsuarios');
        const usuariosItems = document.querySelectorAll('.usuario-item');
        const totalUsuarios = usuariosItems.length;
        
        // Función para filtrar usuarios
        function filtrarUsuarios() {
            const textoBusqueda = inputBuscar.value.toLowerCase().trim();
            let usuariosVisibles = 0;
            
            // Mostrar/ocultar botón de limpiar
            btnLimpiar.style.display = textoBusqueda ? 'block' : 'none';
            
            usuariosItems.forEach(item => {
                const nombre = item.getAttribute('data-nombre');
                const correo = item.getAttribute('data-correo');
                
                // Verificar si el texto de búsqueda está en nombre o correo
                if (nombre.includes(textoBusqueda) || correo.includes(textoBusqueda)) {
                    item.style.display = '';
                    usuariosVisibles++;
                    
                    // Resaltar texto coincidente (opcional)
                    if (textoBusqueda) {
                        resaltarTexto(item, textoBusqueda);
                    } else {
                        eliminarResaltado(item);
                    }
                } else {
                    item.style.display = 'none';
                }
            });
            
            // Actualizar contador
            contadorUsuarios.textContent = usuariosVisibles;
            
            // Mostrar/ocultar mensaje de sin resultados
            if (usuariosVisibles === 0) {
                listaUsuarios.classList.add('d-none');
                sinResultados.classList.remove('d-none');
            } else {
                listaUsuarios.classList.remove('d-none');
                sinResultados.classList.add('d-none');
            }
        }
        
        // Función para resaltar texto
        function resaltarTexto(elemento, texto) {
            // Esta es una versión simplificada, solo marca visualmente
            elemento.style.backgroundColor = elemento.classList.contains('bg-light') ? '#e7f3ff' : '';
        }
        
        // Función para eliminar resaltado
        function eliminarResaltado(elemento) {
            elemento.style.backgroundColor = '';
        }
        
        // Event listeners
        inputBuscar.addEventListener('input', filtrarUsuarios);
        inputBuscar.addEventListener('keyup', function(e) {
            if (e.key === 'Escape') {
                limpiarBusqueda();
            }
        });
        
        btnLimpiar.addEventListener('click', limpiarBusqueda);
        
        function limpiarBusqueda() {
            inputBuscar.value = '';
            filtrarUsuarios();
            inputBuscar.focus();
        }
        
        // Focus automático en el input al cargar
        inputBuscar.focus();
    });
</script>

<partial name="_ValidationScriptsPartial" />
