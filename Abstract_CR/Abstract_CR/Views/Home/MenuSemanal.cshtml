@{
    ViewData["Title"] = "Mi Menú Semanal - Abstract";
}

<!-- Calendario Semanal -->
<section class="page-section">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="text-center mb-5">
                    <h2 class="section-heading">
                        <span class="section-heading-upper" style="color:#e6a756">Esta Semana</span>
                        <span class="section-heading-lower" style="color:#f6e1c5">Lunes a Sábado</span>
                    </h2>
                </div>
            </div>
        </div>

        <div class="row">
            @{
                var diasSemana = new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado" };
                var menus = ViewBag.MenusSemanal as List<Abstract_CR.Models.MenuSemanalViewModel> ?? new List<Abstract_CR.Models.MenuSemanalViewModel>();
                var colores = new[] { "primary", "success", "warning", "info", "danger", "secondary" };
            }
            @for (int i = 0; i < diasSemana.Length; i++)
            {
                var dia = diasSemana[i];
                string diaLimpio = Abstract_CR.Helpers.MenuSemanalHelper.NormalizarDia(dia);
                var menu = menus.FirstOrDefault(m => m.DiaSemanaLimpio == diaLimpio);
                var color = colores[i % colores.Length];
                
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm menu-card">
                        <div data-bs-toggle="modal" data-bs-target="#detalleModal" data-dia="@dia" data-dialimpio="@diaLimpio">
                            <div class="card-header bg-@color text-white text-center">
                                <h5 class="mb-0">@dia</h5>
                            </div>
                            <div class="card-body text-center p-3">
                                @if (menu != null && !string.IsNullOrEmpty(menu.RutaImagen))
                                {
                                    <img src="@menu.RutaImagen" alt="@menu.NombrePlatillo" class="img-fluid rounded mb-3" style="height: 180px; object-fit: cover; width: 100%;" />
                                }
                                else
                                {
                                    <img src="~/assets/img/fondoReceta.jpeg" alt="Platillo" class="img-fluid rounded mb-3" style="height: 180px; object-fit: cover; width: 100%;" />
                                }
                                
                                <h6 class="card-title fw-bold mb-3" style="font-size: 1rem; line-height: 1.3; min-height: 2.5rem; display: flex; align-items: center; justify-content: center;">
                                    @(menu?.NombrePlatillo ?? "Sin platillo asignado")
                                </h6>
                                
                                <!-- Características - Solo mostrar si existen -->
                                @if (menu != null && menu.Caracteristicas != null && menu.Caracteristicas.Any())
                                {
                                    var caracteristicasLimpias = menu.Caracteristicas
                                        .Where(c => !string.IsNullOrWhiteSpace(c) && c != "[]" && c != "null" && !c.StartsWith("[") && !c.EndsWith("]"))
                                        .Select(c => c.Trim().Replace("\"", "").Replace("[", "").Replace("]", ""))
                                        .Where(c => !string.IsNullOrWhiteSpace(c))
                                        .Take(2)
                                        .ToList();
                                    
                                    @if (caracteristicasLimpias.Any())
                                    {
                                        <div class="mb-3 d-flex flex-wrap gap-1 justify-content-center">
                                            @foreach (var caracteristica in caracteristicasLimpias)
                                            {
                                                <span class="badge bg-success text-white" style="font-size: 0.7rem; padding: 0.35rem 0.6rem; border-radius: 6px;">
                                                    <i class="fas fa-check-circle me-1" style="font-size: 0.6rem;"></i>@caracteristica
                                                </span>
                                            }
                                        </div>
                                    }
                                }
                                
                                <div class="d-flex justify-content-center gap-2 mt-auto">
                                    <button class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation(); calificarPlato('@dia.ToLower()', 5);">
                                        <i class="fas fa-thumbs-up"></i> Me gustó
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation(); toggleFavorito('@dia.ToLower()');">
                                        <i class="fas fa-star"></i> Favorito
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Modal Detalle del Día -->
<div class="modal fade" id="detalleModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-calendar-day me-2 text-primary"></i>
                    Detalle del Día - <span id="diaSeleccionado" class="text-primary"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-4">
                    <!-- Columna Izquierda: Imagen -->
                    <div class="col-lg-5">
                        <div class="position-relative">
                            <img id="imagenPlato" src="" alt="Plato" class="img-fluid rounded shadow-sm" style="width: 100%; height: 400px; object-fit: cover;" />
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-light text-dark p-2">
                                    <i class="fas fa-image me-1"></i>Imagen del Platillo
                                </span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Columna Derecha: Información -->
                    <div class="col-lg-7">
                        <!-- Nombre del Platillo -->
                        <h4 id="nombrePlato" class="fw-bold mb-3 text-dark"></h4>
                        
                        <!-- Características -->
                        <div class="mb-4">
                            <h6 class="text-muted mb-3 fw-bold">
                                <i class="fas fa-tags me-2 text-primary"></i>Características Principales
                            </h6>
                            <div id="etiquetasPlato" class="d-flex flex-wrap gap-2">
                                <span class="text-muted">Cargando...</span>
                            </div>
                        </div>

                        <!-- Ingredientes -->
                        <div class="mb-4">
                            <h6 class="text-muted mb-3 fw-bold">
                                <i class="fas fa-list-ul me-2 text-primary"></i>Ingredientes Principales
                            </h6>
                            <div id="ingredientesLista" class="row g-2">
                                <!-- Se llenará dinámicamente -->
                            </div>
                        </div>

                        <!-- Tip del Chef -->
                        <div class="alert alert-info border-start border-4 border-info mb-4">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-lightbulb me-2 mt-1 text-warning"></i>
                                <div>
                                    <strong class="d-block mb-2">Tip del Chef</strong>
                                    <p id="tipChef" class="mb-0 text-muted"></p>
                                </div>
                            </div>
                        </div>

                        <!-- Descripción (si existe) -->
                        <div id="descripcionContainer" class="mb-4" style="display: none;">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-info-circle me-2 text-primary"></i>Descripción
                            </h6>
                            <p id="descripcionPlato" class="text-muted"></p>
                        </div>
                    </div>
                </div>

                <!-- Sección de Comentarios -->
                <div class="px-4 pb-3">
                    <h6 class="text-muted fw-bold mb-2">
                        <i class="fas fa-comments me-2 text-primary"></i>Comentarios
                    </h6>
                    <div id="listaComentariosReceta" class="mb-3" style="max-height: 200px; overflow-y: auto;">
                        <!-- Comentarios cargados dinámicamente -->
                    </div>
                    <div class="input-group">
                        <input type="text" id="nuevoComentarioReceta" class="form-control" placeholder="Escribe un comentario..." />
                        <button class="btn btn-primary" onclick="agregarComentario()">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <a href="@Url.Action("AgregarRestriccion", "Usuario")" class="btn btn-warning">
                    <i class="fas fa-plus me-2"></i>Agregar restricción
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Dirección de Entrega -->
<div class="modal fade" id="direccionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dirección de Entrega</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Provincia</label>
                            <select class="form-select" required>
                                <option value="">Seleccionar provincia</option>
                                <option value="san-jose">San José</option>
                                <option value="alajuela">Alajuela</option>
                                <option value="cartago">Cartago</option>
                                <option value="heredia">Heredia</option>
                                <option value="guanacaste">Guanacaste</option>
                                <option value="puntarenas">Puntarenas</option>
                                <option value="limon">Limón</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cantón</label>
                            <select class="form-select" required>
                                <option value="">Seleccionar cantón</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección exacta</label>
                        <textarea class="form-control" rows="3" placeholder="Dirección completa" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Punto de referencia</label>
                        <input type="text" class="form-control" placeholder="Ej: 100m norte del parque">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" class="form-control" placeholder="8888-8888" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Horario preferido</label>
                            <select class="form-select">
                                <option value="manana">Mañana (8:00 AM - 12:00 PM)</option>
                                <option value="tarde">Tarde (12:00 PM - 5:00 PM)</option>
                                <option value="noche">Noche (5:00 PM - 8:00 PM)</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary">Guardar Cambios</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Pausar Suscripción -->
<div class="modal fade" id="pausarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Pausar Mi Suscripción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Importante:</strong> Al pausar tu suscripción, no recibirás entregas durante el período seleccionado.
                </div>
                <form>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de inicio</label>
                            <input type="date" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de fin</label>
                            <input type="date" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Motivo (opcional)</label>
                        <textarea class="form-control" rows="3" placeholder="¿Por qué pausas tu suscripción?"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning">Pausar Suscripción</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Historial -->
<div class="modal fade" id="historialModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Historial de Entregas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <select class="form-select" id="semanaSelector">
                            <option value="">Seleccionar semana</option>
                            <option value="semana1">Semana del 1-7 Enero 2024</option>
                            <option value="semana2">Semana del 8-14 Enero 2024</option>
                            <option value="semana3">Semana del 15-21 Enero 2024</option>
                        </select>
                    </div>
                </div>
                <div id="historialContenido">
                    <!-- Se llenará dinámicamente -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .menu-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .menu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .btn {
        transition: all 0.3s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    .card-header {
        border-bottom: none;
    }

    .badge {
        font-size: 0.75rem;
    }

    .modal-xl {
        max-width: 1200px;
    }

    .alert-info {
        background-color: #e7f3ff;
        border-color: #b3d9ff;
    }

    #etiquetasPlato {
        min-height: 40px;
    }

    #etiquetasPlato .badge {
        margin-right: 0.5rem !important;
        margin-bottom: 0.5rem !important;
        white-space: nowrap;
        font-size: 0.875rem;
        padding: 0.5rem 0.75rem;
        border-radius: 6px;
    }

    #ingredientesLista {
        min-height: 50px;
    }

    .ingrediente-item {
        background: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        margin-bottom: 0.5rem;
        transition: all 0.2s ease;
    }

    .ingrediente-item:hover {
        background: #e9ecef;
        border-color: #007bff;
        transform: translateX(4px);
    }

    .ingrediente-item i {
        color: #28a745;
        margin-right: 0.5rem;
    }
</style>

<script>
    // Datos de los platos desde el servidor
    const platosData = {};
    @{
        var menusData = ViewBag.MenusSemanal as List<Abstract_CR.Models.MenuSemanalViewModel> ?? new List<Abstract_CR.Models.MenuSemanalViewModel>();
    }
    @foreach (var menu in menusData)
    {
        // Limpiar y normalizar las listas
        var caracteristicasList = (menu.Caracteristicas ?? new List<string>())
            .Where(c => !string.IsNullOrWhiteSpace(c) && c != "[]" && c != "null")
            .Select(c => c.Trim())
            .ToList();
        
        var ingredientesList = (menu.IngredientesPrincipales ?? new List<string>())
            .Where(i => !string.IsNullOrWhiteSpace(i) && i != "[]" && i != "null")
            .Select(i => i.Trim())
            .ToList();
        
        <text>
        platosData['@menu.DiaSemanaLimpio'] = {
            id: @Html.Raw(Json.Serialize(menu.MenuSemanalID ?? 0)),
            nombre: @Html.Raw(Json.Serialize(menu.NombrePlatillo ?? "Sin platillo asignado")),
            imagen: @Html.Raw(Json.Serialize(menu.RutaImagen ?? "/assets/img/fondoReceta.jpeg")),
            etiquetas: @Html.Raw(Json.Serialize(caracteristicasList)),
            ingredientes: @Html.Raw(Json.Serialize(ingredientesList)),
            tipChef: @Html.Raw(Json.Serialize(menu.TipChef ?? "")),
            descripcion: @Html.Raw(Json.Serialize(menu.Descripcion ?? ""))
        };
        </text>
    }
    
    console.log('PlatosData completo:', platosData);

    // Función para mostrar detalles del día
    document.addEventListener('DOMContentLoaded', function () {
        const detalleModal = document.getElementById('detalleModal');
        detalleModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const dia = button.getAttribute('data-dia');
            const diaLimpio = button.getAttribute('data-dialimpio');
            const plato = platosData[diaLimpio];

            document.getElementById('diaSeleccionado').textContent = dia;
            
            if (plato) {
                window.recetaIdActual = plato.id || 0;
                cargarComentarios(window.recetaIdActual);
                document.getElementById('nombrePlato').textContent = plato.nombre || 'Sin platillo asignado';
                document.getElementById('imagenPlato').src = plato.imagen || '/assets/img/fondoReceta.jpeg';

                // Función helper para parsear arrays de forma robusta
                function parsearArray(datos) {
                    if (Array.isArray(datos)) {
                        let resultado = [];
                        datos.forEach(function(item) {
                            if (typeof item === 'string') {
                                try {
                                    const parsed = JSON.parse(item);
                                    if (Array.isArray(parsed)) {
                                        resultado = resultado.concat(parsed);
                                    } else {
                                        resultado.push(item);
                                    }
                                } catch (e) {
                                    if (item.trim() !== '') {
                                        resultado.push(item.trim());
                                    }
                                }
                            } else {
                                resultado.push(item);
                            }
                        });
                        return resultado.filter(item => item && item.toString().trim() !== '' && item.toString() !== '[]' && item.toString() !== 'null');
                    } else if (typeof datos === 'string') {
                        try {
                            const parsed = JSON.parse(datos);
                            if (Array.isArray(parsed)) {
                                return parsearArray(parsed);
                            }
                            return [datos];
                        } catch (e) {
                            return datos.split(',').map(c => c.trim()).filter(c => c && c !== '[]' && c !== 'null');
                        }
                    }
                    return [];
                }
                
                // Mostrar características
                let caracteristicas = parsearArray(plato.etiquetas || []);
                console.log('Características parseadas para', dia, ':', caracteristicas);
                
                const etiquetasContainer = document.getElementById('etiquetasPlato');
                etiquetasContainer.innerHTML = '';
                
                if (caracteristicas.length > 0) {
                    caracteristicas.forEach(function(car) {
                        const texto = car.toString().trim();
                        if (texto && texto !== '[]' && texto !== 'null' && texto.length > 0) {
                            const badge = document.createElement('span');
                            badge.className = 'badge bg-success text-white mb-2 me-2';
                            badge.style.cssText = 'font-size: 0.875rem; padding: 0.5rem 0.75rem; border-radius: 8px; display: inline-block; font-weight: 500;';
                            badge.innerHTML = '<i class="fas fa-check-circle me-1"></i>' + texto;
                            etiquetasContainer.appendChild(badge);
                        }
                    });
                    
                    if (etiquetasContainer.children.length === 0) {
                        etiquetasContainer.innerHTML = '<p class="text-muted mb-0"><i class="fas fa-info-circle me-2"></i>Sin características especificadas</p>';
                    }
                } else {
                    etiquetasContainer.innerHTML = '<p class="text-muted mb-0"><i class="fas fa-info-circle me-2"></i>Sin características especificadas</p>';
                }

                // Mostrar ingredientes
                let ingredientes = parsearArray(plato.ingredientes || []);
                console.log('Ingredientes parseados para', dia, ':', ingredientes);
                
                const ingredientesContainer = document.getElementById('ingredientesLista');
                ingredientesContainer.innerHTML = '';
                
                if (ingredientes.length > 0) {
                    ingredientes.forEach(function(ing) {
                        const texto = ing.toString().trim();
                        if (texto && texto !== '[]' && texto !== 'null' && texto.length > 0) {
                            const div = document.createElement('div');
                            div.className = 'col-md-6 mb-2';
                            div.innerHTML = `
                                <div class="ingrediente-item">
                                    <i class="fas fa-check-circle"></i>
                                    <span class="text-dark fw-semibold">${texto}</span>
                                </div>
                            `;
                            ingredientesContainer.appendChild(div);
                        }
                    });
                    
                    if (ingredientesContainer.children.length === 0) {
                        ingredientesContainer.innerHTML = '<div class="col-12"><p class="text-muted mb-0"><i class="fas fa-info-circle me-2"></i>Sin ingredientes especificados</p></div>';
                    }
                } else {
                    ingredientesContainer.innerHTML = '<div class="col-12"><p class="text-muted mb-0"><i class="fas fa-info-circle me-2"></i>Sin ingredientes especificados</p></div>';
                }

                // Mostrar tip del chef
                const tipChef = plato.tipChef || 'Sin tip disponible';
                document.getElementById('tipChef').textContent = tipChef;
                
                // Mostrar descripción si existe
                if (plato.descripcion && plato.descripcion.trim() !== '') {
                    document.getElementById('descripcionPlato').textContent = plato.descripcion;
                    document.getElementById('descripcionContainer').style.display = 'block';
                } else {
                    document.getElementById('descripcionContainer').style.display = 'none';
                }
            } else {
                window.recetaIdActual = 0;
                cargarComentarios(0);
                document.getElementById('nombrePlato').textContent = 'Sin platillo asignado';
                document.getElementById('imagenPlato').src = '/assets/img/fondoReceta.jpeg';
                document.getElementById('etiquetasPlato').innerHTML = '<p class="text-muted mb-0"><i class="fas fa-info-circle me-2"></i>Sin características especificadas</p>';
                document.getElementById('ingredientesLista').innerHTML = '<div class="col-12"><p class="text-muted mb-0"><i class="fas fa-info-circle me-2"></i>Sin ingredientes especificados</p></div>';
                document.getElementById('tipChef').textContent = 'Sin tip disponible';
                document.getElementById('descripcionContainer').style.display = 'none';
            }
        });
    });

    // Función para calificar plato
    function calificarPlato(dia, calificacion) {
        console.log(`Plato de ${dia} calificado con ${calificacion} estrellas`);
        alert(`¡Gracias por calificar el plato del ${dia}!`);
    }

    // Función para marcar como favorito
    function toggleFavorito(dia) {
        console.log(`Plato de ${dia} marcado como favorito`);
        alert(`Plato del ${dia} agregado a favoritos`);
    }

    function cargarComentarios(recetaId) {
        if (!recetaId || recetaId == 0) {
            $('#listaComentariosReceta').html('<p class="text-muted text-center py-3"><i class="fas fa-comment-slash me-2"></i>Platillo no asignado</p>');
            return;
        }
        $('#listaComentariosReceta').html('<div class="text-center py-3"><i class="fas fa-spinner fa-spin text-primary"></i></div>');
        $.ajax({
            url: '@Url.Action("ObtenerComentariosReceta", "Recetas")?recetaId=' + recetaId,
            type: 'GET',
            success: function(response) {
                if(response.success) {
                    $('#listaComentariosReceta').html(response.html);
                } else {
                    $('#listaComentariosReceta').html('<p class="text-danger text-center py-3">Error al cargar comentarios</p>');
                }
            },
            error: function() {
                $('#listaComentariosReceta').html('<p class="text-danger text-center py-3">Error al procesar la solicitud</p>');
            }
        });
    }

    function agregarComentario() {
        var comentario = $('#nuevoComentarioReceta').val().trim();
        if (!window.recetaIdActual || window.recetaIdActual == 0) {
            alert('No se pueden agregar comentarios a un plato no asignado.');
            return;
        }
        $.ajax({
            url: '@Url.Action("AgregarComentarioReceta", "Recetas")',
            type: 'POST',
            data: { recetaId: window.recetaIdActual, comentario: comentario },
            success: function (response) {
                if (response.success) {
                    $('#listaComentariosReceta').html(response.html);
                    $('#nuevoComentarioReceta').val('');
                } else {
                    mostrarMensajeError('Error al agregar el comentario: ' + response.message);
                }
            },
            error: function (xhr, status, error) {
                alert('Error al procesar la solicitud');
                console.error(error);
            }
        });
    }

    function eliminarComentario(comentarioId) {
        if (!window.recetaIdActual || window.recetaIdActual == 0) return;
        $.ajax({
            url: '@Url.Action("EliminarComentarioReceta", "Recetas")',
            type: 'POST',
            data: { comentarioId: comentarioId, recetaId: window.recetaIdActual },
            success: function (response) {
                if (response.success) {
                    $('#listaComentariosReceta').html(response.html);
                } else {
                    alert('Error al eliminar el comentario: ' + response.message);
                }
            },
            error: function (xhr, status, error) {
                mostrarMensajeError('Error al procesar la solicitud');
                console.error(error);
            }
        });
    }
</script>