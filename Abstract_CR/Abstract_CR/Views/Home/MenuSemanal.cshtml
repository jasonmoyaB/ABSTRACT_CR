@{
    ViewData["Title"] = "Mi Menú Semanal - Abstract";
}

<!-- Header Section -->
<section class="page-section clearfix" style="background: linear-gradient(135deg, rgba(230, 167, 86, 0.1) 0%, rgba(47, 23, 15, 0.05) 100%);">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <div class="intro-text left-0 text-center bg-faded p-5 rounded">
                    <h1 class="section-heading mb-4">
                        <span class="section-heading-upper text-primary">Mi</span>
                        <span class="section-heading-lower">Menú Semanal</span>
                    </h1>
                    <p class="lead mb-4">Tu plan nutricional personalizado de lunes a sábado, adaptado a tus preferencias y alergias.</p>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="text-center">
                    <div class="d-flex justify-content-center gap-3 mb-3">
                        <button class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#direccionModal">
                            <i class="fas fa-map-marker-alt me-2"></i>Dirección
                        </button>
                        <button class="btn btn-outline-warning" data-bs-toggle="modal" data-bs-target="#pausarModal">
                            <i class="fas fa-pause me-2"></i>Pausar
                        </button>
                    </div>
                    <div class="d-flex justify-content-center">
                        <button class="btn btn-outline-secondary"
                                style="color: #e6a756; border-color: #e6a756;"
                                data-bs-toggle="modal"
                                data-bs-target="#historialModal">
                            <i class="fas fa-history me-2"></i>Historial
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Calendario Semanal -->
<section class="page-section">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="text-center mb-5">
                    <h2 class="section-heading">
                        <span class="section-heading-upper" style="color:#e6a756">Esta Semana</span>
                        <span class="section-heading-lower" style="color:#f6e1c5">Lunes a Sábado</span>
                    </h2>
                </div>
            </div>
        </div>

        <div class="row">
            @{
                var diasSemana = new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado" };
                var menus = ViewBag.MenusSemanal as List<Abstract_CR.Models.MenuSemanalViewModel> ?? new List<Abstract_CR.Models.MenuSemanalViewModel>();
                var colores = new[] { "primary", "success", "warning", "info", "danger", "secondary" };
            }
            @for (int i = 0; i < diasSemana.Length; i++)
            {
                var dia = diasSemana[i];
                var menu = menus.FirstOrDefault(m => m.DiaSemana == dia);
                var color = colores[i % colores.Length];
                
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm menu-card">
                        <div data-bs-toggle="modal" data-bs-target="#detalleModal" data-dia="@dia">
                            <div class="card-header bg-@color text-white text-center">
                                <h5 class="mb-0">@dia</h5>
                            </div>
                            <div class="card-body text-center p-4">
                                @if (menu != null && !string.IsNullOrEmpty(menu.RutaImagen))
                                {
                                    <img src="@menu.RutaImagen" alt="@menu.NombrePlatillo" class="img-fluid rounded mb-3" style="height: 150px; object-fit: cover; width: 100%;" />
                                }
                                else
                                {
                                    <img src="~/assets/img/fondoReceta.jpeg" alt="Platillo" class="img-fluid rounded mb-3" style="height: 150px; object-fit: cover; width: 100%;" />
                                }
                                <h6 class="card-title">@(menu?.NombrePlatillo ?? "Sin platillo asignado")</h6>
                                <div class="mb-3 d-flex flex-wrap gap-2 justify-content-center">
                                    @if (menu != null && menu.Caracteristicas != null && menu.Caracteristicas.Any())
                                    {
                                        @foreach (var caracteristica in menu.Caracteristicas.Take(2))
                                        {
                                            <span class="badge bg-success px-3 py-2" style="font-size: 0.85rem; display: inline-block;">@caracteristica</span>
                                        }
                                    }
                                </div>
                                <div class="d-flex justify-content-center gap-2">
                                    <button class="btn btn-sm btn-outline-primary" onclick="event.stopPropagation(); calificarPlato('@dia.ToLower()', 5);">
                                        <i class="fas fa-thumbs-up"></i> Me gustó
                                    </button>
                                    <button class="btn btn-sm btn-outline-warning" onclick="event.stopPropagation(); toggleFavorito('@dia.ToLower()');">
                                        <i class="fas fa-star"></i> Favorito
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Modal Detalle del Día -->
<div class="modal fade" id="detalleModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-calendar-day me-2 text-primary"></i>
                    Detalle del Día - <span id="diaSeleccionado" class="text-primary"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-4">
                    <!-- Columna Izquierda: Imagen -->
                    <div class="col-lg-5">
                        <div class="position-relative">
                            <img id="imagenPlato" src="" alt="Plato" class="img-fluid rounded shadow-sm" style="width: 100%; height: 400px; object-fit: cover;" />
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-light text-dark p-2">
                                    <i class="fas fa-image me-1"></i>Imagen del Platillo
                                </span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Columna Derecha: Información -->
                    <div class="col-lg-7">
                        <!-- Nombre del Platillo -->
                        <h4 id="nombrePlato" class="fw-bold mb-3 text-dark"></h4>
                        
                        <!-- Características -->
                        <div class="mb-4">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-tags me-2 text-primary"></i>Características Principales
                            </h6>
                            <div id="etiquetasPlato" class="d-flex flex-wrap gap-2"></div>
                        </div>

                        <!-- Ingredientes -->
                        <div class="mb-4">
                            <h6 class="text-muted mb-3">
                                <i class="fas fa-list-ul me-2 text-primary"></i>Ingredientes Principales
                            </h6>
                            <ul id="ingredientesLista" class="list-unstyled ps-3">
                                <!-- Se llenará dinámicamente -->
                            </ul>
                        </div>

                        <!-- Tip del Chef -->
                        <div class="alert alert-info border-start border-4 border-info mb-4">
                            <div class="d-flex align-items-start">
                                <i class="fas fa-lightbulb me-2 mt-1 text-warning"></i>
                                <div>
                                    <strong class="d-block mb-2">Tip del Chef</strong>
                                    <p id="tipChef" class="mb-0 text-muted"></p>
                                </div>
                            </div>
                        </div>

                        <!-- Descripción (si existe) -->
                        <div id="descripcionContainer" class="mb-4" style="display: none;">
                            <h6 class="text-muted mb-2">
                                <i class="fas fa-info-circle me-2 text-primary"></i>Descripción
                            </h6>
                            <p id="descripcionPlato" class="text-muted"></p>
                        </div>

                        <!-- Comentarios -->
                        <div class="border-top pt-4">
                            <h6 class="text-muted mb-3">
                                <i class="fas fa-comments me-2 text-primary"></i>Comentarios
                            </h6>
                            <div id="listaComentariosReceta" class="mb-3" style="max-height: 200px; overflow-y: auto;">
                                @if (ViewBag.ComentariosReceta != null && ViewBag.ComentariosReceta.Count > 0)
                                {
                                    <ul class="list-unstyled">
                                        @foreach (var item in ViewBag.ComentariosReceta)
                                        {
                                            <li class="d-flex justify-content-between align-items-start mb-3 p-2 bg-light rounded">
                                                <span class="flex-grow-1">
                                                    <i class="fas fa-comment-dots text-secondary me-2"></i>
                                                    <span class="text-dark">@item.Comentario</span>
                                                </span>
                                                <button class="btn btn-sm btn-outline-danger ms-2"
                                                        data-comentario-id="@item.ComentarioID"
                                                        onclick="event.stopPropagation(); eliminarComentario(@item.ComentarioID);"
                                                        title="Eliminar comentario">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted text-center py-3">
                                        <i class="fas fa-comment-slash me-2"></i>Sin comentarios aún
                                    </p>
                                }
                            </div>
                            
                            <!-- Input para nuevo comentario -->
                            <div class="input-group" onclick="event.stopPropagation();">
                                <input type="text"
                                       class="form-control"
                                       id="nuevoComentarioReceta"
                                       name="nuevoComentarioReceta"
                                       placeholder="Escribe tu comentario aquí..."
                                       onclick="event.stopPropagation();"
                                       onkeydown="event.stopPropagation();">
                                <button class="btn btn-primary" type="button"
                                        onclick="event.stopPropagation(); agregarComentario();"
                                        title="Enviar comentario">
                                    <i class="fas fa-paper-plane me-1"></i>Enviar
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <a href="@Url.Action("AgregarAlergia", "Usuario")" class="btn btn-warning">
                    <i class="fas fa-plus me-2"></i>Agregar nueva alergia
                </a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cerrar
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Dirección de Entrega -->
<div class="modal fade" id="direccionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Dirección de Entrega</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Provincia</label>
                            <select class="form-select" required>
                                <option value="">Seleccionar provincia</option>
                                <option value="san-jose">San José</option>
                                <option value="alajuela">Alajuela</option>
                                <option value="cartago">Cartago</option>
                                <option value="heredia">Heredia</option>
                                <option value="guanacaste">Guanacaste</option>
                                <option value="puntarenas">Puntarenas</option>
                                <option value="limon">Limón</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Cantón</label>
                            <select class="form-select" required>
                                <option value="">Seleccionar cantón</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Dirección exacta</label>
                        <textarea class="form-control" rows="3" placeholder="Dirección completa" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Punto de referencia</label>
                        <input type="text" class="form-control" placeholder="Ej: 100m norte del parque">
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Teléfono</label>
                            <input type="tel" class="form-control" placeholder="8888-8888" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Horario preferido</label>
                            <select class="form-select">
                                <option value="manana">Mañana (8:00 AM - 12:00 PM)</option>
                                <option value="tarde">Tarde (12:00 PM - 5:00 PM)</option>
                                <option value="noche">Noche (5:00 PM - 8:00 PM)</option>
                            </select>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary">Guardar Cambios</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Pausar Suscripción -->
<div class="modal fade" id="pausarModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Pausar Mi Suscripción</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Importante:</strong> Al pausar tu suscripción, no recibirás entregas durante el período seleccionado.
                </div>
                <form>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de inicio</label>
                            <input type="date" class="form-control" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de fin</label>
                            <input type="date" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Motivo (opcional)</label>
                        <textarea class="form-control" rows="3" placeholder="¿Por qué pausas tu suscripción?"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-warning">Pausar Suscripción</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Historial -->
<div class="modal fade" id="historialModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Historial de Entregas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <select class="form-select" id="semanaSelector">
                            <option value="">Seleccionar semana</option>
                            <option value="semana1">Semana del 1-7 Enero 2024</option>
                            <option value="semana2">Semana del 8-14 Enero 2024</option>
                            <option value="semana3">Semana del 15-21 Enero 2024</option>
                        </select>
                    </div>
                </div>
                <div id="historialContenido">
                    <!-- Se llenará dinámicamente -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<style>
    .menu-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .menu-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        }

    .btn {
        transition: all 0.3s ease;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

    .card-header {
        border-bottom: none;
    }

    .badge {
        font-size: 0.75rem;
    }

    #listaComentariosReceta {
        scrollbar-width: thin;
        scrollbar-color: #e6a756 #f5f5f5;
    }

    #listaComentariosReceta::-webkit-scrollbar {
        width: 6px;
    }

    #listaComentariosReceta::-webkit-scrollbar-track {
        background: #f5f5f5;
        border-radius: 10px;
    }

    #listaComentariosReceta::-webkit-scrollbar-thumb {
        background: #e6a756;
        border-radius: 10px;
    }

    #listaComentariosReceta::-webkit-scrollbar-thumb:hover {
        background: #d4954a;
    }

    .modal-xl {
        max-width: 1200px;
    }

    .alert-info {
        background-color: #e7f3ff;
        border-color: #b3d9ff;
    }

    #etiquetasPlato .badge {
        margin-right: 0.5rem !important;
        margin-bottom: 0.5rem !important;
        white-space: nowrap;
    }

    #ingredientesLista li {
        padding: 0.5rem 0;
        border-bottom: 1px solid #f0f0f0;
    }

    #ingredientesLista li:last-child {
        border-bottom: none;
    }
</style>

<script>
    // Datos de los platos desde el servidor
    const platosData = {};
    @{
        var menusData = ViewBag.MenusSemanal as List<Abstract_CR.Models.MenuSemanalViewModel> ?? new List<Abstract_CR.Models.MenuSemanalViewModel>();
    }
    @foreach (var menu in menusData)
    {
        var caracteristicasList = menu.Caracteristicas ?? new List<string>();
        var ingredientesList = menu.IngredientesPrincipales ?? new List<string>();
        <text>
        platosData['@menu.DiaSemana'] = {
            nombre: '@Html.Raw(menu.NombrePlatillo.Replace("'", "\\'").Replace("\"", "&quot;").Replace("\r", "").Replace("\n", " "))',
            imagen: '@(menu.RutaImagen ?? "/assets/img/fondoReceta.jpeg")',
            etiquetas: @Html.Raw(Json.Serialize(caracteristicasList)),
            ingredientes: @Html.Raw(Json.Serialize(ingredientesList)),
            tipChef: '@Html.Raw((menu.TipChef ?? "").Replace("'", "\\'").Replace("\"", "&quot;").Replace("\r", "").Replace("\n", " "))',
            descripcion: '@Html.Raw((menu.Descripcion ?? "").Replace("'", "\\'").Replace("\"", "&quot;").Replace("\r", "").Replace("\n", " "))'
        };
        </text>
    }
    
    // Debug: mostrar todos los datos cargados
    console.log('PlatosData completo:', platosData);

    // Función para mostrar detalles del día
    document.addEventListener('DOMContentLoaded', function () {
        const detalleModal = document.getElementById('detalleModal');
        detalleModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            const dia = button.getAttribute('data-dia');
            const plato = platosData[dia];

            document.getElementById('diaSeleccionado').textContent = dia;
            
            if (plato) {
                document.getElementById('nombrePlato').textContent = plato.nombre || 'Sin platillo asignado';
                document.getElementById('imagenPlato').src = plato.imagen || '/assets/img/fondoReceta.jpeg';

                // Mostrar etiquetas
                let caracteristicas = plato.etiquetas;
                console.log('Características para', dia, ':', caracteristicas, 'Tipo:', typeof caracteristicas);
                
                // Asegurar que sea un array
                if (!Array.isArray(caracteristicas)) {
                    if (typeof caracteristicas === 'string') {
                        try {
                            caracteristicas = JSON.parse(caracteristicas);
                        } catch (e) {
                            caracteristicas = caracteristicas.split(',').map(c => c.trim()).filter(c => c);
                        }
                    } else {
                        caracteristicas = [];
                    }
                }
                
                const etiquetasContainer = document.getElementById('etiquetasPlato');
                etiquetasContainer.innerHTML = ''; // Limpiar primero
                
                if (Array.isArray(caracteristicas) && caracteristicas.length > 0) {
                    caracteristicas.forEach(function(etiqueta) {
                        if (etiqueta && etiqueta.trim && etiqueta.trim() !== '') {
                            const badge = document.createElement('span');
                            badge.className = 'badge bg-success px-3 py-2 mb-2 me-2';
                            badge.style.cssText = 'font-size: 0.85rem; display: inline-block;';
                            badge.textContent = etiqueta.trim();
                            etiquetasContainer.appendChild(badge);
                        }
                    });
                    
                    if (etiquetasContainer.children.length === 0) {
                        etiquetasContainer.innerHTML = '<span class="text-muted">Sin características especificadas</span>';
                    }
                } else {
                    etiquetasContainer.innerHTML = '<span class="text-muted">Sin características especificadas</span>';
                }

                // Mostrar ingredientes
                let ingredientes = plato.ingredientes;
                console.log('Ingredientes para', dia, ':', ingredientes, 'Tipo:', typeof ingredientes);
                
                // Asegurar que sea un array
                if (!Array.isArray(ingredientes)) {
                    if (typeof ingredientes === 'string') {
                        try {
                            ingredientes = JSON.parse(ingredientes);
                        } catch (e) {
                            ingredientes = ingredientes.split(',').map(i => i.trim()).filter(i => i);
                        }
                    } else {
                        ingredientes = [];
                    }
                }
                
                const ingredientesContainer = document.getElementById('ingredientesLista');
                ingredientesContainer.innerHTML = ''; // Limpiar primero
                
                if (Array.isArray(ingredientes) && ingredientes.length > 0) {
                    ingredientes.forEach(function(ingrediente) {
                        if (ingrediente && ingrediente.trim && ingrediente.trim() !== '') {
                            const li = document.createElement('li');
                            li.className = 'mb-2';
                            li.innerHTML = '<i class="fas fa-check-circle text-success me-2"></i><span class="text-dark">' + ingrediente.trim() + '</span>';
                            ingredientesContainer.appendChild(li);
                        }
                    });
                    
                    if (ingredientesContainer.children.length === 0) {
                        ingredientesContainer.innerHTML = '<li class="text-muted"><i class="fas fa-info-circle me-2"></i>Sin ingredientes especificados</li>';
                    }
                } else {
                    ingredientesContainer.innerHTML = '<li class="text-muted"><i class="fas fa-info-circle me-2"></i>Sin ingredientes especificados</li>';
                }

                // Mostrar tip del chef
                const tipChef = plato.tipChef || 'Sin tip disponible';
                document.getElementById('tipChef').textContent = tipChef;
                
                // Mostrar descripción si existe
                if (plato.descripcion && plato.descripcion.trim() !== '') {
                    document.getElementById('descripcionPlato').textContent = plato.descripcion;
                    document.getElementById('descripcionContainer').style.display = 'block';
                } else {
                    document.getElementById('descripcionContainer').style.display = 'none';
                }
            } else {
                document.getElementById('nombrePlato').textContent = 'Sin platillo asignado';
                document.getElementById('imagenPlato').src = '/assets/img/fondoReceta.jpeg';
                document.getElementById('etiquetasPlato').innerHTML = '';
                document.getElementById('ingredientesLista').innerHTML = '<li class="text-muted"><i class="fas fa-info-circle me-2"></i>Sin ingredientes especificados</li>';
                document.getElementById('tipChef').textContent = 'Sin tip disponible';
                document.getElementById('descripcionContainer').style.display = 'none';
            }
        });
    });

    // Función para calificar plato
    function calificarPlato(dia, calificacion) {
        console.log(`Plato de ${dia} calificado con ${calificacion} estrellas`);
        // Aquí se implementaría la lógica para guardar la calificación
        alert(`¡Gracias por calificar el plato del ${dia}!`);
    }

    // Función para marcar como favorito
    function toggleFavorito(dia) {
        console.log(`Plato de ${dia} marcado como favorito`);
        // Aquí se implementaría la lógica para marcar como favorito
        alert(`Plato del ${dia} agregado a favoritos`);
    }

    function agregarComentario() {
        var comentario = $('#nuevoComentarioReceta').val().trim();

        var recetaId = 1;

        $.ajax({
            url: '@Url.Action("AgregarComentarioReceta", "Recetas")',
            type: 'POST',
            data: {
                recetaId: recetaId,
                comentario: comentario
            },
            success: function (response) {
                if (response.success) {
                    // Actualizar la lista de comentarios
                    $('#listaComentariosReceta').html(response.html);

                    // Limpiar el input
                    $('#nuevoComentarioReceta').val('');
                } else {
                    mostrarMensajeError('Error al agregar el comentario: ' + response.message);
                }
            },
            error: function (xhr, status, error) {
                alert('Error al procesar la solicitud');
                console.error(error);
            }
        });
    }

    function eliminarComentario(comentarioId) {
        // Obtener el ID de la receta
        var recetaId = 1;

        $.ajax({
            url: '@Url.Action("EliminarComentarioReceta", "Recetas")',
            type: 'POST',
            data: {
                comentarioId: comentarioId,
                recetaId: recetaId
            },
            success: function (response) {
                if (response.success) {
                    // Actualizar la lista de comentarios
                    $('#listaComentariosReceta').html(response.html);
                } else {
                    alert('Error al eliminar el comentario: ' + response.message);
                }
            },
            error: function (xhr, status, error) {
                mostrarMensajeError('Error al procesar la solicitud');
                console.error(error);
            }
        });
    }

    function mostrarMensajeError(mensaje) {
        var alertHtml = `
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>
                <strong>¡Ups!</strong>
                <p class="mb-0 mt-2">${mensaje}</p>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        `;

        $('#listaComentariosReceta').prepend(alertHtml);

        setTimeout(function () {
            $('.alert-danger').fadeOut('slow', function () {
                $(this).remove();
            });
        }, 5000);
    }

    $(document).ready(function () {
        $('#nuevoComentarioReceta').keypress(function (e) {
            if (e.which === 13) { // Enter key
                e.preventDefault();
                agregarComentario();
            }
        });
    });
</script> 