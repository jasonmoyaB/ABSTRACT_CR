@model Abstract_CR.Models.PlanNutricional

@{
    ViewData["Title"] = "Detalles del Plan";
}

<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />

<style>
    .profile-section {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        color: white;
    }
    .modern-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .modern-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }
    .card-header-modern {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border: none;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e9ecef;
    }
    .icon-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        margin-right: 0.75rem;
    }
    .nutrition-card {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s ease;
    }
    .nutrition-card:hover {
        border-color: #007FFF;
        box-shadow: 0 4px 12px rgba(0, 127, 255, 0.15);
        transform: translateY(-2px);
    }
</style>

<section class="page-section" style="padding: 2rem 0;">
    <div class="container">
        <!-- Header -->
        <div class="profile-section text-center mb-4 position-relative">
            <a href="@Url.Action("Index", "PlanNutricional")" 
               class="btn position-absolute" 
               style="left: 1rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white; border-radius: 12px; padding: 0.5rem 1rem;"
               title="Volver a Mis Planes">
                <i class="fas fa-arrow-left me-2"></i> Volver
            </a>
            <div class="d-flex align-items-center justify-content-center mb-3">
                <div class="icon-circle">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <div class="text-start ms-3">
                    <h3 class="mb-0 fw-bold">Detalles del Plan Nutricional</h3>
                    <p class="mb-0 opacity-75">@Model.Nombre</p>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="modern-card bg-white">
                    <div class="card-header-modern d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-clipboard-list me-2"></i>
                            @Model.Nombre
                        </h4>
                        <div class="btn-group" role="group">
                            @if (!string.IsNullOrEmpty(Model.DocumentoURL))
                            {
                                <a href="@Model.DocumentoURL" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-download me-1"></i>
                                    Descargar
                                </a>
                            }
                            <a href="@Url.Action("Delete", "PlanNutricional", new { id = Model.PlanID })" 
                               class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('¿Estás seguro de que deseas eliminar este plan?')">
                                <i class="fas fa-trash me-1"></i>
                                Eliminar
                            </a>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <!-- Información General -->
                            <div class="col-md-8">
                                <h5 class="border-bottom pb-2 mb-3">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Información General
                                </h5>

                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <strong>Nombre del Plan:</strong>
                                    </div>
                                    <div class="col-sm-8">
                                        @Model.Nombre
                                    </div>
                                </div>

                                @if (!string.IsNullOrEmpty(Model.Descripcion))
                                {
                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>Descripción:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            @Model.Descripcion
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(Model.TipoPlan))
                                {
                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>Tipo de Plan:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-info">@Model.TipoPlan</span>
                                        </div>
                                    </div>
                                }

                                @if (!string.IsNullOrEmpty(Model.Estado))
                                {
                                    <div class="row mb-3">
                                        <div class="col-sm-4">
                                            <strong>Estado:</strong>
                                        </div>
                                        <div class="col-sm-8">
                                            <span class="badge @(Model.Estado == "Activo" ? "bg-success" : "bg-warning")">
                                                @Model.Estado
                                            </span>
                                        </div>
                                    </div>
                                }

                                <!-- Información Nutricional -->
                                @if (Model.CaloriasDiarias.HasValue || Model.Proteinas.HasValue || Model.Carbohidratos.HasValue || Model.Grasas.HasValue || Model.Fibra.HasValue)
                                {
                                    <h5 class="border-bottom pb-2 mb-3 mt-4">
                                        <i class="fas fa-chart-pie me-2"></i>
                                        Información Nutricional
                                    </h5>

                                    <div class="row">
                                        @if (Model.CaloriasDiarias.HasValue)
                                        {
                                            <div class="col-sm-6 col-lg-4 mb-3">
                                                <div class="nutrition-card">
                                                    <i class="fas fa-fire text-danger fa-2x mb-2"></i>
                                                    <h6 class="mb-1 fw-bold">Calorías</h6>
                                                    <strong class="text-dark">@Model.CaloriasDiarias kcal</strong>
                                                </div>
                                            </div>
                                        }

                                        @if (Model.Proteinas.HasValue)
                                        {
                                            <div class="col-sm-6 col-lg-4 mb-3">
                                                <div class="nutrition-card">
                                                    <i class="fas fa-dumbbell text-primary fa-2x mb-2"></i>
                                                    <h6 class="mb-1 fw-bold">Proteínas</h6>
                                                    <strong class="text-dark">@Model.Proteinas g</strong>
                                                </div>
                                            </div>
                                        }

                                        @if (Model.Carbohidratos.HasValue)
                                        {
                                            <div class="col-sm-6 col-lg-4 mb-3">
                                                <div class="nutrition-card">
                                                    <i class="fas fa-bread-slice text-warning fa-2x mb-2"></i>
                                                    <h6 class="mb-1 fw-bold">Carbohidratos</h6>
                                                    <strong class="text-dark">@Model.Carbohidratos g</strong>
                                                </div>
                                            </div>
                                        }

                                        @if (Model.Grasas.HasValue)
                                        {
                                            <div class="col-sm-6 col-lg-4 mb-3">
                                                <div class="nutrition-card">
                                                    <i class="fas fa-seedling text-success fa-2x mb-2"></i>
                                                    <h6 class="mb-1 fw-bold">Grasas</h6>
                                                    <strong class="text-dark">@Model.Grasas g</strong>
                                                </div>
                                            </div>
                                        }

                                        @if (Model.Fibra.HasValue)
                                        {
                                            <div class="col-sm-6 col-lg-4 mb-3">
                                                <div class="nutrition-card">
                                                    <i class="fas fa-leaf text-info fa-2x mb-2"></i>
                                                    <h6 class="mb-1 fw-bold">Fibra</h6>
                                                    <strong class="text-dark">@Model.Fibra g</strong>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>

                            <!-- Panel Lateral -->
                            <div class="col-md-4">
                                <div class="card bg-light">
                                    <div class="card-header">
                                        <h6 class="mb-0">
                                            <i class="fas fa-calendar me-2"></i>
                                            Fechas Importantes
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <small class="text-muted d-block">Fecha de Carga</small>
                                            <strong>@Model.FechaCarga.ToString("dd/MM/yyyy HH:mm")</strong>
                                        </div>

                                        @if (Model.FechaInicio.HasValue)
                                        {
                                            <div class="mb-3">
                                                <small class="text-muted d-block">Fecha de Inicio</small>
                                                <strong>@Model.FechaInicio.Value.ToString("dd/MM/yyyy")</strong>
                                            </div>
                                        }

                                        @if (Model.FechaVencimiento.HasValue)
                                        {
                                            var isExpired = Model.FechaVencimiento < DateTime.Today;
                                            var isExpiringSoon = Model.FechaVencimiento <= DateTime.Today.AddDays(7) && !isExpired;
                                            var daysRemaining = (Model.FechaVencimiento.Value - DateTime.Today).Days;

                                            <div class="mb-3">
                                                <small class="text-muted d-block">Fecha de Vencimiento</small>
                                                <strong class="@(isExpired ? "text-danger" : isExpiringSoon ? "text-warning" : "text-success")">
                                                    @Model.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                                </strong>
                                                @if (isExpired)
                                                {
                                                    <div class="mt-1">
                                                        <span class="badge bg-danger">
                                                            <i class="fas fa-exclamation-triangle me-1"></i>
                                                            Vencido
                                                        </span>
                                                    </div>
                                                }
                                                else if (isExpiringSoon)
                                                {
                                                    <div class="mt-1">
                                                        <span class="badge bg-warning">
                                                            <i class="fas fa-clock me-1"></i>
                                                            Vence en @daysRemaining días
                                                        </span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="mt-1">
                                                        <span class="badge bg-success">
                                                            <i class="fas fa-check me-1"></i>
                                                            @daysRemaining días restantes
                                                        </span>
                                                    </div>
                                                }
                                            </div>
                                        }

                                        @if (!string.IsNullOrEmpty(Model.DocumentoURL))
                                        {
                                            <hr>
                                            <div class="mb-3">
                                                <small class="text-muted d-block">Documento</small>
                                                <a href="@Model.DocumentoURL" target="_blank" class="btn btn-outline-primary btn-sm">
                                                    <i class="fas fa-file-download me-1"></i>
                                                    Ver/Descargar
                                                </a>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <!-- Acciones -->
                                <div class="card mt-3">
                                    <div class="card-header">
                                        <h6 class="mb-0">
                                            <i class="fas fa-cogs me-2"></i>
                                            Acciones
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="d-grid gap-2">
                                            @if (!string.IsNullOrEmpty(Model.DocumentoURL))
                                            {
                                                <a href="@Model.DocumentoURL" target="_blank" class="btn btn-primary btn-sm">
                                                    <i class="fas fa-download me-2"></i>
                                                    Descargar Plan
                                                </a>
                                            }

                                            <hr>

                                            <a href="@Url.Action("Delete", "PlanNutricional", new { id = Model.PlanID })"
                                               class="btn btn-outline-danger btn-sm"
                                               onclick="return confirm('¿Estás seguro de que deseas eliminar este plan?')">
                                                <i class="fas fa-trash me-2"></i>
                                                Eliminar Plan
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección de Evaluaciones -->
        @{
            var evaluaciones = ViewBag.Evaluaciones as List<dynamic> ?? new List<dynamic>();
        }
        @if (evaluaciones.Any())
        {
            <div class="row justify-content-center mt-4">
                <div class="col-lg-10">
                    <div class="modern-card bg-white">
                        <div class="card-header-modern">
                            <h5 class="mb-0 fw-bold text-dark">
                                <i class="fas fa-star-half-stroke me-2"></i> Evaluaciones del Plan
                            </h5>
                        </div>
                        <div class="card-body p-4">
                            @foreach (var evaluacion in evaluaciones)
                            {
                                <div class="border rounded-3 p-4 mb-3" style="background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <h6 class="mb-1 fw-bold">
                                                @if (evaluacion.EsAdmin)
                                                {
                                                    <span class="badge bg-primary me-2">Chef</span>
                                                }
                                                @evaluacion.UsuarioNombre
                                            </h6>
                                            @if (evaluacion.FechaRegistro != null)
                                            {
                                                <small class="text-muted">
                                                    <i class="fas fa-calendar me-1"></i>
                                                    @(((DateTime)evaluacion.FechaRegistro).ToString("dd/MM/yyyy HH:mm"))
                                                </small>
                                            }
                                        </div>
                                        @if (evaluacion.Calificacion != null)
                                        {
                                            <div>
                                                <span class="badge bg-warning text-dark fs-6">
                                                    @for (int i = 0; i < evaluacion.Calificacion; i++)
                                                    {
                                                        <i class="fas fa-star"></i>
                                                    }
                                                    @evaluacion.Calificacion / 5
                                                </span>
                                            </div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(evaluacion.Comentario))
                                    {
                                        <div class="mt-3 p-3 rounded" style="background: white; border-left: 4px solid #007FFF;">
                                            <p class="mb-0 text-dark">@evaluacion.Comentario</p>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>