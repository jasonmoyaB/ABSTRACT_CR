@model Abstract_CR.Models.EvaluacionPlanViewModel

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Evaluar Plan Nutricional";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0 text-primary"><i class="fa-solid fa-star-half-stroke me-2"></i> Evaluar Plan Nutricional</h1>
                <p class="text-muted mb-0">Evalúa el plan nutricional del cliente</p>
            </div>
            <a href="@Url.Action("VerTodosLosPlanes", "PlanNutricional")" class="btn btn-outline-secondary">
                <i class="fa-solid fa-arrow-left me-2"></i> Volver
            </a>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-clipboard-list me-2"></i>
                        Plan: @Model.NombrePlanActual
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="EvaluarPlanAdmin" asp-controller="PlanNutricional" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="PlanID" value="@Model.PlanID" />
                        <input type="hidden" name="NombrePlanActual" value="@Model.NombrePlanActual" />

                        <!-- Calificación -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                Calificación (1 a 5) <span class="text-danger">*</span>
                            </label>
                            <div class="d-flex flex-wrap gap-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" 
                                               type="radio" 
                                               name="Calificacion" 
                                               id="cal-@i" 
                                               value="@i" 
                                               @(Model.Calificacion == i ? "checked" : "") 
                                               required />
                                        <label class="form-check-label fw-semibold" for="cal-@i">
                                            @i ⭐
                                        </label>
                                    </div>
                                }
                            </div>
                            <span class="text-danger d-block mt-1" asp-validation-for="Calificacion"></span>
                        </div>

                        <!-- Comentario -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                Comentario o Observaciones <span class="text-danger">*</span>
                            </label>
                            <textarea class="form-control" 
                                      name="Comentario" 
                                      rows="5" 
                                      maxlength="1000" 
                                      placeholder="Escribe tus observaciones sobre el plan nutricional del cliente..."
                                      required>@Model.Comentario</textarea>
                            <div class="form-text">Máximo 1000 caracteres</div>
                            <span class="text-danger d-block mt-1" asp-validation-for="Comentario"></span>
                        </div>

                        <!-- Mensaje de validación general -->
                        @if (!string.IsNullOrEmpty(Model.ErrorMensaje))
                        {
                            <div class="alert alert-warning">
                                <i class="fa-solid fa-circle-exclamation me-2"></i>
                                @Model.ErrorMensaje
                            </div>
                        }

                        <!-- Botones -->
                        <div class="d-flex justify-content-end gap-2">
                            <a href="@Url.Action("VerTodosLosPlanes", "PlanNutricional")" class="btn btn-outline-secondary">
                                <i class="fa-solid fa-times me-2"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa-solid fa-paper-plane me-2"></i> Guardar Evaluación
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

