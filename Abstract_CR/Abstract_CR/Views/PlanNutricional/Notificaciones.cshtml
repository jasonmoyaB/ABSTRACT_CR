@using Abstract_CR.Models
@model List<Notificacion>

@{
    ViewData["Title"] = "Notificaciones";
}
<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />
<style>
    .profile-section {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        color: white;
    }
    .modern-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .modern-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }
    .card-header-modern {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border: none;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e9ecef;
    }
    .notification-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        border-left: 4px solid #FFA500;
        transition: all 0.3s ease;
    }
    .notification-item:hover {
        background: #e9ecef;
        transform: translateX(4px);
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .info-item {
        background: linear-gradient(135deg, #e6f5ff 0%, #d6f0ff 100%);
        border-radius: 12px;
        padding: 1rem;
        margin-bottom: 0.75rem;
        border-left: 4px solid #007FFF;
        transition: all 0.3s ease;
    }
    .info-item:hover {
        box-shadow: 0 4px 12px rgba(0, 127, 255, 0.3);
        transform: translateX(4px);
    }
    .icon-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        margin-right: 0.75rem;
    }
</style>

<section class="page-section" style="padding: 2rem 0;">
    <div class="container">
        <!-- Header -->
        <div class="profile-section text-center mb-4 position-relative">
            <a href="@Url.Action("Perfil", "Usuario")" 
               class="btn position-absolute" 
               style="left: 1rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white; border-radius: 12px; padding: 0.5rem 1rem;"
               title="Volver al Perfil">
                <i class="fas fa-arrow-left me-2"></i> Volver
            </a>
            <div class="d-flex align-items-center justify-content-center mb-3">
                <div class="icon-circle">
                    <i class="fas fa-bell"></i>
                </div>
                <div class="text-start ms-3">
                    <h3 class="mb-0 fw-bold">Mis Notificaciones</h3>
                    <p class="mb-0 opacity-75">Alertas y recordatorios de tu plan</p>
                </div>
            </div>
        </div>

        <!-- Notificaciones -->
        <div class="row">
            <div class="col-lg-12">
                <div class="modern-card bg-white mb-4">
                    <div class="card-header-modern">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-bell me-2"></i>
                            Notificaciones del Plan
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var notificacion in Model)
                            {
                                <div class="notification-item">
                                    <div class="d-flex align-items-start">
                                        <div class="flex-shrink-0 me-3">
                                            <div class="icon-circle" style="width: 35px; height: 35px; background: linear-gradient(135deg, #FFA500 0%, #FF8C00 100%);">
                                                <i class="fas fa-exclamation-triangle"></i>
                                            </div>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-2 fw-bold text-dark">@notificacion.Tipo</h6>
                                            <p class="mb-2 text-dark">@notificacion.Mensaje</p>
                                            <small class="text-muted">
                                                <i class="fas fa-calendar me-1"></i>
                                                @notificacion.FechaEnvio.ToString("dd/MM/yyyy HH:mm")
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-bell-slash fa-3x text-muted mb-3 opacity-50"></i>
                                <h5 class="text-muted mb-2">No hay notificaciones</h5>
                                <p class="text-muted">No tienes notificaciones pendientes en este momento.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Configuración de notificaciones (informativa) -->
        <div class="row mt-4">
            <div class="col-lg-12">
                <div class="modern-card bg-white">
                    <div class="card-header-modern">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-info-circle me-2"></i>
                            Configuración de Notificaciones
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <p class="mb-4 text-dark">
                            Aquí puedes ver cómo funcionan tus notificaciones en Abstract.
                            Las notificaciones te ayudan a mantenerte al día con tus planes nutricionales
                            y otros recordatorios importantes relacionados con tu dieta y hábitos saludables.
                        </p>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <h6 class="mb-3 fw-bold text-dark">Recordatorios de Vencimiento</h6>
                                <div class="info-item">
                                    <strong class="d-block mb-1">7 días antes del vencimiento:</strong>
                                    <small class="text-muted">Te avisamos una semana antes de que tu plan expire para que puedas renovarlo o revisarlo a tiempo.</small>
                                </div>
                                <div class="info-item">
                                    <strong class="d-block mb-1">3 días antes del vencimiento:</strong>
                                    <small class="text-muted">Un recordatorio cercano para que no olvides tu plan.</small>
                                </div>
                                <div class="info-item">
                                    <strong class="d-block mb-1">1 día antes del vencimiento:</strong>
                                    <small class="text-muted">Último aviso para que tomes acción antes de que el plan caduque.</small>
                                </div>
                                <div class="info-item">
                                    <strong class="d-block mb-1">El día del vencimiento:</strong>
                                    <small class="text-muted">Te notificamos si tu plan ha llegado a su fecha final.</small>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <h6 class="mb-3 fw-bold text-dark">Otros Recordatorios</h6>
                                <div class="info-item">
                                    <strong class="d-block mb-1">Evaluar el plan:</strong>
                                    <small class="text-muted">Te recordamos que puedes dejar tu evaluación sobre cómo funcionó tu plan.</small>
                                </div>
                                <div class="info-item">
                                    <strong class="d-block mb-1">Nuevos menús disponibles:</strong>
                                    <small class="text-muted">Te avisamos cuando se agregan nuevos menús para que tengas más opciones saludables.</small>
                                </div>
                                <div class="info-item">
                                    <strong class="d-block mb-1">Consejos nutricionales semanales:</strong>
                                    <small class="text-muted">Recibirás recomendaciones y consejos de nutrición para mantener hábitos saludables.</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelector('button[type="button"]').addEventListener('click', function () {
            alert('Configuración guardada exitosamente.');
        });
    </script>
}