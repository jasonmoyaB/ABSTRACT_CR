@model Abstract_CR.Models.RestriccionAlimentaria

@{
    ViewData["Title"] = "Agregar Restricción Alimentaria";
}

<section class="page-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-plus-circle me-2"></i>Información de la Restricción</h5>
                    </div>
                    <div class="card-body">

                        <form asp-action="AgregarRestriccion" asp-controller="Usuario" method="post">
                            @Html.AntiForgeryToken()

                            <!-- El UsuarioID se toma de la sesión, igual lo dejamos oculto -->
                            <input type="hidden" asp-for="UsuarioID" />

                            <div class="mb-3">
                                <label asp-for="Descripcion" class="form-label"></label>
                                <textarea asp-for="Descripcion" class="form-control" rows="4"
                                          placeholder="Ejemplo: No consumir gluten, lácteos o mariscos"></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>
                            </div>

                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-primary btn-lg me-3">
                                    <i class="fas fa-save me-2"></i>Guardar Restricción
                                </button>

                                <a href="@Url.Action("Restricciones", "Usuario")"
                                   class="btn btn-outline-secondary btn-lg">
                                    <i class="fas fa-times me-2"></i>Cancelar
                                </a>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
