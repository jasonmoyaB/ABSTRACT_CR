@model Abstract_CR.Models.RestriccionAlimentaria

@{
    ViewData["Title"] = "Agregar Restricción Alimentaria";
}
<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />
<style>
    .profile-section {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        color: white;
    }
    .modern-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .modern-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }
    .card-header-modern {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border: none;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e9ecef;
    }
    .form-control-modern {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
    }
    .form-control-modern:focus {
        border-color: #007FFF;
        box-shadow: 0 0 0 0.2rem rgba(0, 127, 255, 0.25);
    }
    .btn-save {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-save:hover {
        box-shadow: 0 4px 12px rgba(0, 127, 255, 0.4);
        transform: translateY(-2px);
        color: white;
    }
    .btn-cancel {
        border: 2px solid #007FFF;
        color: #007FFF;
        background: white;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-cancel:hover {
        background: linear-gradient(135deg, #e6f5ff 0%, #d6f0ff 100%);
        color: #007FFF;
    }
    .icon-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        margin-right: 0.75rem;
    }
</style>

<section class="page-section" style="padding: 2rem 0;">
    <div class="container">
        <!-- Header -->
        <div class="profile-section text-center mb-4 position-relative">
            <a href="@Url.Action("Restricciones", "Usuario")" 
               class="btn position-absolute" 
               style="left: 1rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white; border-radius: 12px; padding: 0.5rem 1rem;"
               title="Volver a Restricciones">
                <i class="fas fa-arrow-left me-2"></i> Volver
            </a>
            <div class="d-flex align-items-center justify-content-center mb-3">
                <div class="icon-circle">
                    <i class="fas fa-plus-circle"></i>
                </div>
                <div class="text-start ms-3">
                    <h3 class="mb-0 fw-bold">Agregar Restricción Alimentaria</h3>
                    <p class="mb-0 opacity-75">Registra tus restricciones dietéticas</p>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="modern-card bg-white">
                    <div class="card-header-modern">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-plus-circle me-2"></i> Información de la Restricción
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="AgregarRestriccion" asp-controller="Usuario" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" asp-for="UsuarioID" />

                            <div class="mb-4">
                                <label asp-for="Descripcion" class="form-label fw-bold text-secondary small text-uppercase mb-2"></label>
                                <textarea asp-for="Descripcion" class="form-control form-control-modern" rows="4"
                                          placeholder="Ejemplo: No consumir gluten, lácteos o mariscos"></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>
                            </div>

                            <div class="text-center mt-4">
                                <button type="submit" class="btn btn-save me-3">
                                    <i class="fas fa-save me-2"></i> Guardar Restricción
                                </button>
                                <a href="@Url.Action("Restricciones", "Usuario")" class="btn btn-cancel">
                                    <i class="fas fa-times me-2"></i> Cancelar
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
