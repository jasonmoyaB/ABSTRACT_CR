@model List<Abstract_CR.Models.UsuarioInteraccionResumen>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />

<style>
    .admin-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        color: white;
    }

    .user-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .user-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        transform: translateY(-4px);
    }

    .user-card-header {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e9ecef;
    }

    .status-badge {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.875rem;
    }

    .status-badge.active {
        background: #10b981;
        color: white;
    }

    .status-badge.inactive {
        background: #ef4444;
        color: white;
    }

    .btn-toggle-status {
        border-radius: 12px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        transition: all 0.3s ease;
        border: none;
    }

    .btn-toggle-status.btn-activate {
        background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        color: white;
    }

    .btn-toggle-status.btn-activate:hover {
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
        transform: translateY(-2px);
    }

    .btn-toggle-status.btn-deactivate {
        background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
        color: white;
    }

    .btn-toggle-status.btn-deactivate:hover {
        box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
        transform: translateY(-2px);
    }

    .btn-view-profile {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-view-profile:hover {
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        transform: translateY(-2px);
        color: white;
    }

    .info-item {
        padding: 0.75rem;
        background: #f8f9fa;
        border-radius: 8px;
        margin-bottom: 0.5rem;
    }

    .search-box {
        border-radius: 12px;
        border: 2px solid #e9ecef;
        padding: 0.75rem 1.25rem;
        transition: all 0.3s ease;
    }

    .search-box:focus {
        border-color: #667eea;
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }
</style>

<section class="page-section" style="padding: 2rem 0;">
    <div class="container">
        <!-- Header -->
        <div class="admin-header text-center mb-4">
            <h2 class="mb-2 fw-bold">
                <i class="fas fa-users-cog me-2"></i>
                Gestión de Usuarios
            </h2>
            <p class="mb-0 opacity-75">Administra y controla el estado de los usuarios de la plataforma</p>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Filtro de búsqueda -->
        <div class="mb-4">
            <input type="text" id="searchInput" class="form-control search-box" 
                   placeholder="🔍 Buscar por nombre o correo electrónico...">
        </div>

        <!-- Estadísticas -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="user-card bg-white">
                    <div class="card-body text-center">
                        <h3 class="fw-bold text-primary mb-2">@Model.Count</h3>
                        <p class="text-muted mb-0">Total Usuarios</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="user-card bg-white">
                    <div class="card-body text-center">
                        <h3 class="fw-bold text-success mb-2">@Model.Count(u => u.Activo)</h3>
                        <p class="text-muted mb-0">Usuarios Activos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="user-card bg-white">
                    <div class="card-body text-center">
                        <h3 class="fw-bold text-danger mb-2">@Model.Count(u => !u.Activo)</h3>
                        <p class="text-muted mb-0">Usuarios Inactivos</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lista de usuarios -->
        <div id="usuariosList">
            @if (Model.Any())
            {
                foreach (var usuario in Model.OrderBy(u => u.NombreCompleto))
                {
                    <div class="user-card bg-white usuario-item" 
                         data-nombre="@usuario.NombreCompleto.ToLower()" 
                         data-email="@usuario.CorreoElectronico.ToLower()">
                        <div class="user-card-header">
                            <div class="row align-items-center">
                                <div class="col-md-6">
                                    <h5 class="mb-1 fw-bold text-dark">
                                        <i class="fas fa-user-circle me-2"></i>
                                        @usuario.NombreCompleto
                                    </h5>
                                    <small class="text-muted">@usuario.CorreoElectronico</small>
                                </div>
                                <div class="col-md-6 text-md-end mt-2 mt-md-0">
                                    <span class="status-badge @(usuario.Activo ? "active" : "inactive")" id="status-badge-@usuario.UsuarioId">
                                        <i class="fas @(usuario.Activo ? "fa-check-circle" : "fa-times-circle") me-1"></i>
                                        @(usuario.Activo ? "Activo" : "Inactivo")
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="info-item">
                                                <small class="text-muted d-block mb-1">
                                                    <i class="fas fa-star me-1"></i> Puntos Totales
                                                </small>
                                                <strong>@usuario.PuntosTotales puntos</strong>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="info-item">
                                                <small class="text-muted d-block mb-1">
                                                    <i class="fas fa-calendar me-1"></i> Última Actividad
                                                </small>
                                                <strong>
                                                    @(usuario.UltimaActividad.HasValue 
                                                        ? usuario.UltimaActividad.Value.ToString("dd/MM/yyyy") 
                                                        : "Sin actividad")
                                                </strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                    <div class="d-flex flex-column gap-2">
                                        <!-- Botón para ver perfil -->
                                        <a href="@Url.Action("Perfil", "Usuario", new { id = usuario.UsuarioId })" 
                                           class="btn btn-view-profile">
                                            <i class="fas fa-eye me-2"></i>Ver Perfil
                                        </a>

                                        <!-- ✅ BOTÓN PARA ACTIVAR/DESACTIVAR USUARIO -->
                                        <button type="button" 
                                                class="btn btn-toggle-status @(usuario.Activo ? "btn-deactivate" : "btn-activate")" 
                                                data-usuario-id="@usuario.UsuarioId"
                                                data-usuario-nombre="@usuario.NombreCompleto"
                                                data-activar="@(!usuario.Activo)"
                                                onclick="cambiarEstadoUsuario(this)">
                                            <i class="fas @(usuario.Activo ? "fa-ban" : "fa-check-circle") me-2"></i>
                                            @(usuario.Activo ? "Desactivar" : "Activar")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-users fa-3x mb-3 opacity-50"></i>
                    <p class="mb-0 fs-5">No hay usuarios registrados</p>
                </div>
            }
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Función para filtrar usuarios
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const usuarioItems = document.querySelectorAll('.usuario-item');

            usuarioItems.forEach(item => {
                const nombre = item.dataset.nombre;
                const email = item.dataset.email;
                
                if (nombre.includes(searchTerm) || email.includes(searchTerm)) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });
        });

        // Función para cambiar el estado del usuario
        function cambiarEstadoUsuario(button) {
            const usuarioId = button.dataset.usuarioId;
            const usuarioNombre = button.dataset.usuarioNombre;
            const activar = button.dataset.activar === 'true';
            const accion = activar ? 'activar' : 'desactivar';

            if (!confirm(`¿Estás seguro de que deseas ${accion} al usuario "${usuarioNombre}"?`)) {
                return;
            }

            // Hace POST al controlador
            fetch('@Url.Action("CambiarEstadoUsuario", "Usuario")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: `usuarioId=${usuarioId}&activar=${activar}&__RequestVerificationToken=${token}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Actualizar la UI
                    const statusBadge = document.getElementById(`status-badge-${usuarioId}`);
                    
                    if (data.nuevoEstado) {
                        statusBadge.className = 'status-badge active';
                        statusBadge.innerHTML = '<i class="fas fa-check-circle me-1"></i>Activo';
                        
                        button.className = 'btn btn-toggle-status btn-deactivate';
                        button.dataset.activar = 'false';
                        button.innerHTML = '<i class="fas fa-ban me-2"></i>Desactivar';
                    } else {
                        statusBadge.className = 'status-badge inactive';
                        statusBadge.innerHTML = '<i class="fas fa-times-circle me-1"></i>Inactivo';
                        
                        button.className = 'btn btn-toggle-status btn-activate';
                        button.dataset.activar = 'true';
                        button.innerHTML = '<i class="fas fa-check-circle me-2"></i>Activar';
                    }
                    
                    button.disabled = false;

                    // Mostrar mensaje de éxito
                    alert(data.message);
                    
                    // Actualizar contadores
                    location.reload();
                } else {
                    alert(data.message || 'Error al cambiar el estado del usuario');
                    button.disabled = false;
                    button.innerHTML = `<i class="fas ${activar ? 'fa-check-circle' : 'fa-ban'} me-2"></i>${activar ? 'Activar' : 'Desactivar'}`;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error al procesar la solicitud');
                button.disabled = false;
                button.innerHTML = `<i class="fas ${activar ? 'fa-check-circle' : 'fa-ban'} me-2"></i>${activar ? 'Activar' : 'Desactivar'}`;
            });
        }
    </script>
    @Html.AntiForgeryToken()
}