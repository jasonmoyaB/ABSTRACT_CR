@model Abstract_CR.Models.PerfilInteraccionViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}
<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />
<link href="~/css/perfil.css" rel="stylesheet" />

<section class="page-section">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12 text-center">
                <h2 class="section-heading">
                    <span class="section-heading-upper" style="color:#e6a756">Mi Perfil</span>
                    <span class="section-heading-lower" style="color:#f6e1c5">Información Personal</span>
                </h2>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">
            <!-- Mini menú / navegación -->
            <div class="col-lg-3 mb-4">
                <div class="card shadow-sm sticky-top" style="top:20px;">
                    <div class="card-body p-2">
                        <ul class="nav nav-pills flex-column" id="perfilTabs" role="tablist">
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link active d-flex align-items-center" id="info-tab" data-bs-toggle="pill" data-bs-target="#info" type="button" role="tab" aria-controls="info" aria-selected="true">
                                    <i class="fas fa-user me-2"></i> Información
                                </button>
                            </li>
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="chef-tab" data-bs-toggle="pill" data-bs-target="#chef" type="button" role="tab" aria-controls="chef" aria-selected="false">
                                    <i class="fas fa-comments me-2"></i> Mensajeria
                                    @* <span class="badge bg-primary ms-auto">@Model.Usuario.PuntosTotales</span> *@
                                </button>
                            </li>
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="salud-tab" data-bs-toggle="pill" data-bs-target="#salud" type="button" role="tab" aria-controls="salud" aria-selected="false">
                                    <i class="fas fa-cogs me-2"></i> Salud
                                </button>
                            </li>
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="cuenta-tab" data-bs-toggle="pill" data-bs-target="#cuenta" type="button" role="tab" aria-controls="cuenta" aria-selected="false">
                                    <i class="fas fa-info-circle me-2"></i> Cuenta
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="resumen-tab" data-bs-toggle="pill" data-bs-target="#resumen" type="button" role="tab" aria-controls="resumen" aria-selected="false">
                                    <i class="fas fa-bell me-2"></i> Resúmenes
                                </button>
                            </li>
                        </ul>
                        <hr />
                        <div class="text-center small text-muted">Selecciona una sección para ver</div>
                    </div>
                </div>
            </div>

            <!-- Contenido principal -->
            <div class="col-lg-9">
                <div class="tab-content" id="perfilTabsContent">

                    <!-- Información Personal -->
                    <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="info-tab">
                        <div class="card shadow-sm mb-4 border-0">
                            <!-- Header con fondo café oscuro y texto beige -->
                            <div class="card-header bg-dark text-light d-flex justify-content-between align-items-center"
                                 style="background-color: #3C2313 !important; color: #f6e1c5 !important;">
                                <h5 class="mb-0 fw-semibold">
                                    <i class="fas fa-user me-2" style="color: #f6e1c5;"></i>
                                    Información Personal
                                </h5>
                                <a href="@Url.Action("EditarPerfil", "Usuario")"
                                   class="btn btn-sm border-light text-light fw-semibold"
                                   style="--bs-btn-hover-bg: #f6e1c5; --bs-btn-hover-color: #3C2313;">
                                    <i class="fas fa-edit me-1" style="color: #f6e1c5;"></i> Editar
                                </a>
                            </div>

                            <!-- Cuerpo con fondo blanco -->
                            <div class="card-body bg-white">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold text-secondary">Nombre Completo</label>
                                        <p class="form-control-plaintext fw-semibold text-dark mb-0">@Model.Usuario.NombreCompleto</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold text-secondary">Correo Electrónico</label>
                                        <p class="form-control-plaintext fw-semibold text-dark mb-0">@Model.Usuario.CorreoElectronico</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold text-secondary">Fecha de Registro</label>
                                        <p class="form-control-plaintext fw-semibold text-dark mb-0">
                                            @(Model.Usuario.FechaRegistro?.ToString("dd/MM/yyyy") ?? "No especificada")
                                        </p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold text-secondary">Rol</label>
                                        <p class="form-control-plaintext fw-semibold text-dark mb-0">
                                            @(Model.Usuario.Rol?.NombreRol ?? "No especificado")
                                        </p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold text-secondary">Estado</label>
                                        <p class="form-control-plaintext fw-semibold text-dark mb-0">
                                            @if (Model.Usuario.Activo)
                                            {
                                                <span style="background-color:#3C2313 !important; color: #f6e1c5 !important; color:white" " class="badge bg-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactivo</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Conversación con el Chef -->
                    <div class="tab-pane fade" id="chef" role="tabpanel" aria-labelledby="chef-tab">
                        <div class="card shadow-sm mb-4 border-0">
                            <!-- Header con mismo esquema de color -->
                            <div class="card-header d-flex justify-content-between align-items-center"
                                 style="background-color: #3C2313 !important; color: #f6e1c5 !important;">
                                <h5 class="mb-0 fw-semibold">
                                    <i class="fas fa-comments me-2" style="color: #f6e1c5;"></i>
                                    Conversación con el Chef
                                </h5>
                                <span class="badge rounded-pill"
                                      style="background-color: #e6a756; color: #3C2313; font-weight:600;">
                                    <i class="fas fa-star me-1"></i>@Model.Usuario.PuntosTotales pts
                                </span>
                            </div>

                            <!-- Cuerpo del chat -->
                            <div class="card-body bg-white" style="max-height: 450px; overflow-y: auto;">
                                @if (Model.Mensajes.Any())
                                {
                                    foreach (var mensaje in Model.Mensajes.OrderBy(m => m.FechaEnvio))
                                    {
                                        var esChef = mensaje.EnviadoPorChef;
                                        var clase = esChef ? "bg-warning text-dark" : "bg-light";
                                        var alineacion = esChef ? "text-end" : "text-start";
                                        <div class="mb-3">
                                            <div class="@alineacion">
                                                <div class="small text-muted mb-1">
                                                    @(esChef
                                                                                                ? (mensaje.Tipo == Abstract_CR.Models.TipoMensajeInteraccion.ResumenSemanal ? "Resumen del Chef" : "Chef")
                                                                                                : "Yo")
                                            · @mensaje.FechaEnvio.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                        <div class="d-inline-block p-3 rounded-3 @clase shadow-sm" style="max-width: 80%;">
                                            @mensaje.Contenido
                                        </div>
                                    </div>
                                </div>
                                                                }
                                }
                                else
                                {
                                    <div class="text-center text-muted py-4">
                                        <i class="fas fa-inbox fa-2x mb-3"></i>
                                        <p class="mb-0">Aún no tienes mensajes. Empieza la conversación con tu chef.</p>
                                    </div>
                                }
                            </div>

                            <!-- Footer para enviar mensaje -->
                            <div class="card-footer bg-white">
                                <form asp-action="EnviarMensajeChef" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="UsuarioId" value="@Model.Usuario.UsuarioID" />
                                    <div class="mb-3">
                                        <label class="form-label fw-bold text-secondary">Escribe tu mensaje</label>
                                        <textarea class="form-control" name="Contenido" rows="3" placeholder="Comparte tus dudas, logros o comentarios..."></textarea>
                                    </div>
                                    <div class="text-end">
                                        <button type="submit" class="btn fw-semibold text-light border-0"
                                                style="background-color: #3C2313; --bs-btn-hover-bg: #e6a756; --bs-btn-hover-color: #3C2313;">
                                            <i class="fas fa-paper-plane me-2"></i>Enviar
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Gestión de Salud -->
                    <div class="tab-pane fade" id="salud" role="tabpanel" aria-labelledby="salud-tab">
                        <div class="card shadow-sm mb-4 border-0">
                            <div class="card-header" style="background-color: #3c2313;">
                                <h5 class="mb-0" style="color: #f6e1c5;">
                                    <i class="fas fa-cogs me-2" style="color: #f6e1c5;"></i> Gestión de Salud
                                </h5>
                            </div>

                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Alergias", "Usuario")"
                                           class="btn w-100 text-start custom-btn d-flex align-items-center justify-content-between">
                                            <div><i class="fas fa-allergies me-2"></i> Mis Alergias</div>
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Restricciones", "Usuario")"
                                           class="btn w-100 text-start custom-btn d-flex align-items-center justify-content-between">
                                            <div><i class="fas fa-ban me-2"></i> Mis Restricciones</div>
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Preferencias", "Usuario")"
                                           class="btn w-100 text-start custom-btn d-flex align-items-center justify-content-between">
                                            <div><i class="fas fa-heart me-2"></i> Mis Preferencias</div>
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </div>

                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Index", "PlanNutricional")"
                                           class="btn w-100 text-start custom-btn d-flex align-items-center justify-content-between">
                                            <div><i class="fas fa-apple-alt me-2"></i> Mi Plan</div>
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </div>

                                    <div class="col-12">
                                        <a href="@Url.Action("Notificaciones", "PlanNutricional")"
                                           class="btn w-100 text-start custom-btn d-flex align-items-center justify-content-between">
                                            <div><i class="fas fa-bell me-2"></i> Notificaciones</div>
                                            <i class="fas fa-chevron-right"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                   


                    <!-- Información de Cuenta -->
                    <div class="tab-pane fade" id="cuenta" role="tabpanel" aria-labelledby="cuenta-tab">
                        <div class="card shadow-sm mb-4 border-0">
                            <div class="card-header" style="background-color: #3c2313; color: #f6e1c5;">
                                <h5 class="mb-0">
                                    <i class="fas fa-info-circle me-2" style="color: #f6e1c5;"></i> Información de Cuenta
                                </h5>
                            </div>

                            <div class="card-body" style="background-color: #fefaf6;">
                                <div class="mb-3">
                                    <label class="form-label fw-bold text-dark">Miembro desde</label>
                                    <p class="form-control-plaintext" style="color: #3c2313;">
                                        @(Model.Usuario.FechaRegistro?.ToString("dd/MM/yyyy") ?? "No especificada")
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold text-dark">Puntos acumulados</label>
                                    <p class="form-control-plaintext">
                                        <span class="badge fs-6" style="background-color: #3c2313; color: #f6e1c5;">
                                            <i class="fas fa-star me-2"></i>@Model.Usuario.PuntosTotales puntos
                                        </span>
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold text-dark">Últimas asignaciones</label>

                                    @if (Model.HistorialPuntos.Any())
                                    {
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var registro in Model.HistorialPuntos.Take(5))
                                            {
                                                <li class="mb-3 p-2 rounded-3 d-flex justify-content-between align-items-center shadow-sm"
                                                    style="background-color: #fffbea; border: 1px solid #e0c9a6;">
                                                    <div>
                                                        <div class="fw-semibold" style="color:@(registro.Puntos >= 0 ? "#3c2313" : "#c0392b");">
                                                            @(registro.Puntos >= 0 ? "+" : "")@registro.Puntos pts
                                                        </div>
                                                        <small class="text-muted">@registro.FechaAsignacion.ToString("dd/MM")</small>
                                                    </div>
                                                    <small class="text-muted text-end ms-3">
                                                        @(string.IsNullOrWhiteSpace(registro.Motivo) ? "Sin motivo" : registro.Motivo)
                                                    </small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="form-control-plaintext text-muted">Aún no tienes puntos asignados.</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                  


                    <!-- Resúmenes Semanales -->
                    <div class="tab-pane fade" id="resumen" role="tabpanel" aria-labelledby="resumen-tab">
                        <div  class="card shadow-sm mb-4">
                            <div style="background-color: #3c2313; color: #f6e1c5;" class="card-header bg-faded">
                                <h5 class="mb-0"><i class="fas fa-bell me-2"></i> Resúmenes Semanales</h5>
                            </div>
                            <div class="card-body">
                                @if (Model.Mensajes.Any(m => m.Tipo == Abstract_CR.Models.TipoMensajeInteraccion.ResumenSemanal))
                                {
                                    <div class="list-group list-group-flush">
                                        @foreach (var resumen in Model.Mensajes
                                                                            .Where(m => m.Tipo == Abstract_CR.Models.TipoMensajeInteraccion.ResumenSemanal)
                                                                            .OrderByDescending(m => m.FechaEnvio)
                                                                            .Take(5))
                                        {
                                            <div class="list-group-item px-0">
                                                <div class="d-flex justify-content-between">
                                                    <div class="fw-semibold">Resumen del @resumen.FechaEnvio.ToString("dd/MM")</div>
                                                    <small class="text-muted">@resumen.FechaEnvio.ToString("HH:mm")</small>
                                                </div>
                                                <div class="text-muted small mt-2">@resumen.Contenido</div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">Tu chef aún no te envía resúmenes semanales.</p>
                                }
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>


<partial name="_ValidationScriptsPartial" />