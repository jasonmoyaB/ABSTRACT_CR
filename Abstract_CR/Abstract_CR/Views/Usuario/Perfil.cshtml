@model Abstract_CR.Models.PerfilInteraccionViewModel
@{
    ViewData["Title"] = "Mi Perfil";
}
<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />

<section class="page-section">
    <div class="container">
        <div class="row mb-4">
            <div class="col-12 text-center">
                <h2 class="section-heading">
                    <span class="section-heading-upper" style="color:#e6a756">Mi Perfil</span>
                    <span class="section-heading-lower" style="color:#f6e1c5">Información Personal</span>
                </h2>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">
            <!-- Mini menú / navegación -->
            <div class="col-lg-3 mb-4">
                <div class="card shadow-sm sticky-top" style="top:20px;">
                    <div class="card-body p-2">
                        <ul class="nav nav-pills flex-column" id="perfilTabs" role="tablist">
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link active d-flex align-items-center" id="info-tab" data-bs-toggle="pill" data-bs-target="#info" type="button" role="tab" aria-controls="info" aria-selected="true">
                                    <i class="fas fa-user me-2"></i> Información
                                </button>
                            </li>
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="chef-tab" data-bs-toggle="pill" data-bs-target="#chef" type="button" role="tab" aria-controls="chef" aria-selected="false">
                                    <i class="fas fa-comments me-2"></i> Mensajeria
                                    @* <span class="badge bg-primary ms-auto">@Model.Usuario.PuntosTotales</span> *@
                                </button>
                            </li>
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="salud-tab" data-bs-toggle="pill" data-bs-target="#salud" type="button" role="tab" aria-controls="salud" aria-selected="false">
                                    <i class="fas fa-cogs me-2"></i> Salud
                                </button>
                            </li>
                            <li class="nav-item mb-2" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="cuenta-tab" data-bs-toggle="pill" data-bs-target="#cuenta" type="button" role="tab" aria-controls="cuenta" aria-selected="false">
                                    <i class="fas fa-info-circle me-2"></i> Cuenta
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link d-flex align-items-center" id="resumen-tab" data-bs-toggle="pill" data-bs-target="#resumen" type="button" role="tab" aria-controls="resumen" aria-selected="false">
                                    <i class="fas fa-bell me-2"></i> Resúmenes
                                </button>
                            </li>
                        </ul>
                        <hr />
                        <div class="text-center small text-muted">Selecciona una sección para ver</div>
                    </div>
                </div>
            </div>

            <!-- Contenido principal -->
            <div class="col-lg-9">
                <div class="tab-content" id="perfilTabsContent">

                    <!-- Información Personal -->
                    <div class="tab-pane fade show active" id="info" role="tabpanel" aria-labelledby="info-tab">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-faded d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="fas fa-user me-2"></i> Información Personal</h5>
                                <a style="color: black" href="@Url.Action("EditarPerfil", "Usuario")" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit me-1" style="color: black"></i> Editar
                                </a>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Nombre Completo</label>
                                        <p class="form-control-plaintext">@Model.Usuario.NombreCompleto</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Correo Electrónico</label>
                                        <p class="form-control-plaintext">@Model.Usuario.CorreoElectronico</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Fecha de Registro</label>
                                        <p class="form-control-plaintext">@(Model.Usuario.FechaRegistro?.ToString("dd/MM/yyyy") ?? "No especificada")</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Rol</label>
                                        <p class="form-control-plaintext">@(Model.Usuario.Rol?.NombreRol ?? "No especificado")</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Estado</label>
                                        <p class="form-control-plaintext">
                                            @if (Model.Usuario.Activo)
                                            {
                                                <span class="badge bg-success">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactivo</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Conversación con el Chef -->
                    <div class="tab-pane fade" id="chef" role="tabpanel" aria-labelledby="chef-tab">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-faded d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="fas fa-comments me-2"></i> Conversación con el Chef</h5>
                                <span class="badge bg-primary"><i class="fas fa-star me-1"></i>@Model.Usuario.PuntosTotales pts</span>
                            </div>
                            <div class="card-body" style="max-height: 450px; overflow-y: auto;">
                                @if (Model.Mensajes.Any())
                                {
                                    foreach (var mensaje in Model.Mensajes.OrderBy(m => m.FechaEnvio))
                                    {
                                        var esChef = mensaje.EnviadoPorChef;
                                        var clase = esChef ? "bg-primary text-white" : "bg-light";
                                        var alineacion = esChef ? "text-end" : "text-start";
                                        <div class="mb-3">
                                            <div class="@alineacion">
                                                <div class="small text-muted mb-1">
                                                    @(esChef
                                                                                                ? (mensaje.Tipo == Abstract_CR.Models.TipoMensajeInteraccion.ResumenSemanal ? "Resumen del Chef" : "Chef")
                                                                                                : "Yo")
                                            · @mensaje.FechaEnvio.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                        <div class="d-inline-block p-3 rounded-3 @clase" style="max-width: 80%;">
                                            @mensaje.Contenido
                                        </div>
                                    </div>
                                </div>
                                                                }
                                }
                                else
                                {
                                    <div class="text-center text-muted py-4">
                                        <i class="fas fa-inbox fa-2x mb-3"></i>
                                        <p class="mb-0">Aún no tienes mensajes. Empieza la conversación con tu chef.</p>
                                    </div>
                                }
                            </div>
                            <div class="card-footer bg-white">
                                <form asp-action="EnviarMensajeChef" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="UsuarioId" value="@Model.Usuario.UsuarioID" />
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Escribe tu mensaje</label>
                                        <textarea class="form-control" name="Contenido" rows="3" placeholder="Comparte tus dudas, logros o comentarios..."></textarea>
                                    </div>
                                    <div class="text-end">
                                        <button type="submit" class="btn btn-primary"><i class="fas fa-paper-plane me-2"></i>Enviar</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <!-- Gestión de Salud -->
                    <div class="tab-pane fade" id="salud" role="tabpanel" aria-labelledby="salud-tab">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-faded">
                                <h5 class="mb-0"><i class="fas fa-cogs me-2"></i> Gestión de Salud</h5>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Alergias", "Usuario")" class="btn btn-outline-primary w-100 text-start" style="color:black">
                                            <i class="fas fa-allergies me-2"></i> Mis Alergias
                                        </a>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Restricciones", "Usuario")" class="btn btn-outline-primary w-100 text-start" style="color:black">
                                            <i class="fas fa-ban me-2"></i> Mis Restricciones
                                        </a>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Preferencias", "Usuario")" class="btn btn-outline-primary w-100 text-start" style="color:black">
                                            <i class="fas fa-heart me-2"></i> Mis Preferencias
                                        </a>
                                    </div>
                                    <div class="col-12 col-md-6">
                                        <a href="@Url.Action("Index", "PlanNutricional")" class="btn btn-outline-primary w-100 text-start" style="color:black">
                                            <i class="fas fa-apple-alt me-2"></i> Mi plan
                                        </a>
                                    </div>
                                    <div class="col-12">
                                        <a href="@Url.Action("Notificaciones", "PlanNutricional")" class="btn btn-outline-primary w-100 text-start" style="color:black">
                                            <i class="fas fa-bell me-2"></i> Notificaciones
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Información de Cuenta -->
                    <div class="tab-pane fade" id="cuenta" role="tabpanel" aria-labelledby="cuenta-tab">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-faded">
                                <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i> Información de Cuenta</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Miembro desde</label>
                                    <p class="form-control-plaintext">@(Model.Usuario.FechaRegistro?.ToString("dd/MM/yyyy") ?? "No especificada")</p>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Puntos acumulados</label>
                                    <p class="form-control-plaintext">
                                        <span class="badge bg-primary fs-6"><i class="fas fa-star me-2"></i>@Model.Usuario.PuntosTotales puntos</span>
                                    </p>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Últimas asignaciones</label>
                                    @if (Model.HistorialPuntos.Any())
                                    {
                                        <ul class="list-unstyled mb-0">
                                            @foreach (var registro in Model.HistorialPuntos.Take(5))
                                            {
                                                <li class="mb-2 d-flex justify-content-between">
                                                    <div>
                                                        <div class="fw-semibold @(registro.Puntos >= 0 ? "text-success" : "text-danger")">@(registro.Puntos >= 0 ? "+" : "")@registro.Puntos pts</div>
                                                        <small class="text-muted">@registro.FechaAsignacion.ToString("dd/MM")</small>
                                                    </div>
                                                    <small class="text-muted text-end ms-3">@(string.IsNullOrWhiteSpace(registro.Motivo) ? "Sin motivo" : registro.Motivo)</small>
                                                </li>
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <p class="form-control-plaintext text-muted">Aún no tienes puntos asignados.</p>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Resúmenes Semanales -->
                    <div class="tab-pane fade" id="resumen" role="tabpanel" aria-labelledby="resumen-tab">
                        <div class="card shadow-sm mb-4">
                            <div class="card-header bg-faded">
                                <h5 class="mb-0"><i class="fas fa-bell me-2"></i> Resúmenes Semanales</h5>
                            </div>
                            <div class="card-body">
                                @if (Model.Mensajes.Any(m => m.Tipo == Abstract_CR.Models.TipoMensajeInteraccion.ResumenSemanal))
                                {
                                    <div class="list-group list-group-flush">
                                        @foreach (var resumen in Model.Mensajes
                                                                            .Where(m => m.Tipo == Abstract_CR.Models.TipoMensajeInteraccion.ResumenSemanal)
                                                                            .OrderByDescending(m => m.FechaEnvio)
                                                                            .Take(5))
                                        {
                                            <div class="list-group-item px-0">
                                                <div class="d-flex justify-content-between">
                                                    <div class="fw-semibold">Resumen del @resumen.FechaEnvio.ToString("dd/MM")</div>
                                                    <small class="text-muted">@resumen.FechaEnvio.ToString("HH:mm")</small>
                                                </div>
                                                <div class="text-muted small mt-2">@resumen.Contenido</div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <p class="text-muted mb-0">Tu chef aún no te envía resúmenes semanales.</p>
                                }
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</section>
<style>
    /* Estilos elegantes para la tarjeta de Información Personal */
    .perfil-card {
        border: 1px solid rgba(33,37,41,0.05);
        border-radius: 12px;
        overflow: hidden;
    }

    .perfil-header {
        background: linear-gradient(90deg, rgba(230,167,86,0.08), rgba(246,225,197,0.03));
        padding: 1rem 1.25rem;
        display: flex;
        gap: 1rem;
        align-items: center;
    }

    .perfil-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background-color: #fff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        color: #e6a756;
        font-size: 24px;
        border: 2px solid rgba(230,167,86,0.18);
        box-shadow: 0 6px 18px rgba(16,24,40,0.04);
    }

    .perfil-nombre {
        font-size: 1.05rem;
        font-weight: 700;
        color: #212529;
        margin-bottom: 0;
    }

    .perfil-rol {
        font-size: 0.9rem;
        color: #6c757d;
    }

    .perfil-body {
        padding: 1.25rem;
        background: #fff;
    }

    .perfil-row .form-label {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 0.25rem;
    }

    .perfil-row .form-control-plaintext {
        font-weight: 600;
        color: #212529;
        margin-bottom: 0.75rem;
    }

    .perfil-badge {
        border-radius: 999px;
        padding: .35rem .6rem;
        font-weight: 600;
        font-size: .85rem;
    }

    /* Botón editar más neutro y elegante */
    .btn-editar-perfil {
        color: #212529;
        border-color: transparent;
        background-color: rgba(0,0,0,0.04);
        box-shadow: none;
        font-weight: 600;
        border-radius: 8px;
    }

        .btn-editar-perfil:hover {
            background-color: #e6a756;
            color: #fff;
        }
    /* --- Estilo personalizado del mini menú --- */
    .nav-pills .nav-link {
        color: #212529; /* negro suave */
        font-weight: 500;
        /* background-color: #f8f9fa; /* gris claro de fondo */ */
        border-radius: 0.5rem;
        transition: all 0.2s ease-in-out;
    }

        .nav-pills .nav-link:hover {
            color: #000;
            background-color: #e6a7561a; /* toque dorado al pasar el mouse */
            transform: scale(1.02);
        }

        .nav-pills .nav-link.active {
            color: #fff !important;
            background-color: #3C2313 !important; /* dorado principal */
            box-shadow: 0 0 6px rgba(230, 167, 86, 0.6);
        }

        /* Íconos del menú */
        .nav-pills .nav-link i {
            color: #e6a756;
        }

        .nav-pills .nav-link.active i {
            color: #fff;
        }
</style>

<partial name="_ValidationScriptsPartial" />