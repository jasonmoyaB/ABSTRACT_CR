@model List<Abstract_CR.Models.RestriccionAlimentaria>

@{
    ViewData["Title"] = "Mis Restricciones Alimentarias";
}

<section class="page-section">

    <div class="container">


        <div class="row">
            <div class="col-lg-12">
                <div class="position-relative mb-5">
                    <a href="@Url.Action("Perfil", "Usuario")"
                       class="btn position-absolute"
                       style="left: 0; top: 0; background-color: #2F170F; border-color: #2F170F; color: white;"
                       title="Volver a Mi Perfil">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <div class="text-center">
                        <h2 class="section-heading">
                            <span class="section-heading-upper" style="color:#e6a756">Mis</span>
                            <span class="section-heading-lower" style="color:#f6e1c5">Restricciones Alimentarias</span>
                        </h2>
                    </div>
                </div>
            </div>
        </div>
        <div class="container-fluid py-4">

            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["Mensaje"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }


        <div class="row">
            <div class="col-lg-12">
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-faded d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-ban me-2"></i>
                            Lista de Restricciones Alimentarias
                        </h5>

                        <a href="@Url.Action("AgregarRestriccion", "Usuario")"
                           class="btn btn-primary">
                            <i class="fas fa-plus me-2"></i>
                            Agregar Restricción
                        </a>
                    </div>

                    <div class="card-body">
                        @if (Model != null && Model.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Descripción</th>
                                            <th class="text-end">Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.Descripcion</td>
                                                <td class="text-end">
                                                    <form asp-action="EliminarRestriccion" method="post" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.RestriccionID" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                            <i class="fas fa-trash-alt"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-ban fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No tienes restricciones registradas</h5>

                                <a href="@Url.Action("AgregarRestriccion", "Usuario")"
                                   class="btn btn-primary mt-3">
                                    <i class="fas fa-plus me-2"></i>
                                    Agregar Restricción
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
