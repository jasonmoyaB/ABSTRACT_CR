@model List<Abstract_CR.Models.RestriccionAlimentaria>

@{
    ViewData["Title"] = "Mis Restricciones Alimentarias";
}
<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />
<style>
    .profile-section {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        color: white;
    }
    .modern-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .modern-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }
    .card-header-modern {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border: none;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e9ecef;
    }
    .restriction-item {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.75rem;
        border-left: 4px solid #007FFF;
        transition: all 0.3s ease;
    }
    .restriction-item:hover {
        background: #e9ecef;
        transform: translateX(4px);
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }
    .btn-add {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.5rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-add:hover {
        box-shadow: 0 4px 12px rgba(0, 127, 255, 0.4);
        transform: translateY(-2px);
        color: white;
    }
    .btn-delete {
        border-radius: 8px;
        padding: 0.5rem 1rem;
        transition: all 0.3s ease;
    }
    .icon-circle {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        margin-right: 0.75rem;
    }
</style>

<section class="page-section" style="padding: 2rem 0;">
    <div class="container">
        <!-- Header -->
        <div class="profile-section text-center mb-4 position-relative">
            <a href="@Url.Action("Perfil", "Usuario")" 
               class="btn position-absolute" 
               style="left: 1rem; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.3); color: white; border-radius: 12px; padding: 0.5rem 1rem;"
               title="Volver al Perfil">
                <i class="fas fa-arrow-left me-2"></i> Volver
            </a>
            <div class="d-flex align-items-center justify-content-center mb-3">
                <div class="icon-circle">
                    <i class="fas fa-ban"></i>
                </div>
                <div class="text-start ms-3">
                    <h3 class="mb-0 fw-bold">Mis Restricciones Alimentarias</h3>
                    <p class="mb-0 opacity-75">Gestiona tus restricciones dietéticas</p>
                </div>
            </div>
        </div>

        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                <i class="fas fa-check-circle me-2"></i>
                @TempData["Mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row">
            <div class="col-lg-12">
                <div class="modern-card bg-white mb-4">
                    <div class="card-header-modern d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-ban me-2"></i>
                            Lista de Restricciones Alimentarias
                        </h5>
                        <a href="@Url.Action("AgregarRestriccion", "Usuario")" class="btn btn-add">
                            <i class="fas fa-plus me-2"></i>
                            Agregar Restricción
                        </a>
                    </div>

                    <div class="card-body p-4">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <div class="restriction-item d-flex justify-content-between align-items-center">
                                    <div class="flex-grow-1">
                                        <p class="mb-0 fw-semibold text-dark">@item.Descripcion</p>
                                    </div>
                                    <div>
                                        <form asp-action="EliminarRestriccion" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.RestriccionID" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger btn-delete" title="Eliminar">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-ban fa-3x text-muted mb-3 opacity-50"></i>
                                <h5 class="text-muted mb-3">No tienes restricciones registradas</h5>
                                <a href="@Url.Action("AgregarRestriccion", "Usuario")" class="btn btn-add">
                                    <i class="fas fa-plus me-2"></i>
                                    Agregar Restricción
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
