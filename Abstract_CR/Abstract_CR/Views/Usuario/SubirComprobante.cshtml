@model Abstract_CR.Models.ComprobantePago
@{
    ViewData["Title"] = "Subir Comprobante de Pago";
}

<link rel="icon" type="image/x-icon" href="~/assets/img/LOGO01.jfif" />

<style>
    .profile-section {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        color: white;
    }
    .modern-card {
        border: none;
        border-radius: 16px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .modern-card:hover {
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }
    .card-header-modern {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border: none;
        padding: 1.25rem 1.5rem;
        border-bottom: 2px solid #e9ecef;
    }
    .form-control-modern {
        border: 2px solid #e9ecef;
        border-radius: 12px;
        padding: 0.75rem 1rem;
        transition: all 0.3s ease;
    }
    .form-control-modern:focus {
        border-color: #007FFF;
        box-shadow: 0 0 0 0.2rem rgba(0, 127, 255, 0.25);
    }
    .btn-upload {
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-upload:hover {
        box-shadow: 0 4px 12px rgba(0, 127, 255, 0.4);
        transform: translateY(-2px);
        color: white;
    }
    .btn-cancel {
        border: 2px solid #007FFF;
        color: #007FFF;
        background: white;
        border-radius: 12px;
        padding: 0.75rem 2rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    .btn-cancel:hover {
        background: linear-gradient(135deg, #e6f5ff 0%, #d6f0ff 100%);
        color: #007FFF;
    }
    .icon-circle {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%);
        color: white;
    }
    .file-preview {
        border: 2px dashed #e9ecef;
        border-radius: 12px;
        padding: 2rem;
        text-align: center;
        background: #f8f9fa;
        margin-top: 1rem;
        transition: all 0.3s ease;
    }
    .file-preview:hover {
        border-color: #007FFF;
        background: linear-gradient(135deg, #e6f5ff 0%, #d6f0ff 100%);
    }
    .file-preview img {
        max-width: 100%;
        max-height: 300px;
        border-radius: 8px;
    }
    .info-item {
        padding: 1rem;
        background: #f8f9fa;
        border-radius: 12px;
        margin-bottom: 1rem;
        border-left: 4px solid #007FFF;
        transition: all 0.3s ease;
    }
    .info-item:hover {
        background: #e9ecef;
        transform: translateX(4px);
    }
</style>

<section class="page-section" style="padding: 2rem 0;">
    <div class="container">
        <!-- Header -->
        <div class="profile-section text-center mb-4">
            <div class="d-flex align-items-center justify-content-center mb-3">
                <div class="icon-circle">
                    <i class="fas fa-receipt fa-2x"></i>
                </div>
                <div class="text-start ms-3">
                    <h3 class="mb-0 fw-bold">Subir Comprobante de Pago</h3>
                    <p class="mb-0 opacity-75">Adjunta el comprobante de tu pago para que sea revisado</p>
                </div>
            </div>
        </div>

        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="modern-card bg-white">
                    <div class="card-header-modern">
                        <h5 class="mb-0 fw-bold text-dark">
                            <i class="fas fa-file-upload me-2"></i>
                            Formulario de Comprobante
                        </h5>
                    </div>
                    <div class="card-body p-4">

                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @TempData["Mensaje"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm" role="alert">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="SubirComprobante" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label for="archivo" class="form-label fw-bold text-secondary small text-uppercase mb-2">
                                <i class="fas fa-file-upload me-2"></i>Comprobante de Pago
                            </label>
                            <input type="file" id="archivo" name="archivo" class="form-control form-control-modern"
                                   accept=".pdf,.jpg,.jpeg,.png,.gif" required />
                            <div class="form-text">
                                <i class="fas fa-info-circle me-2"></i>
                                Formatos permitidos: PDF, JPG, JPEG, PNG, GIF. Tamaño máximo: 10MB
                            </div>
                            <span asp-validation-for="Archivo" class="text-danger"></span>
                            <div id="archivoPreview" class="file-preview d-none">
                                <div id="previewContent"></div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Observaciones" class="form-label fw-bold text-secondary small text-uppercase mb-2">
                                <i class="fas fa-comment me-2"></i>Observaciones (Opcional)
                            </label>
                            <textarea asp-for="Observaciones" class="form-control form-control-modern" rows="3"
                                      placeholder="Agrega cualquier información adicional sobre el pago (número de transacción, referencia, etc.)"></textarea>
                            <span asp-validation-for="Observaciones" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-4">
                            <a href="@Url.Action("Perfil", "Usuario")" class="btn btn-cancel">
                                <i class="fas fa-arrow-left me-2"></i>Volver al Perfil
                            </a>
                            <button type="submit" class="btn btn-upload">
                                <i class="fas fa-upload me-2"></i>Subir Comprobante
                            </button>
                        </div>
                    </form>
                    </div>
                </div>

                <div class="text-center mt-4">
                    <a href="@Url.Action("VerComprobantes", "Usuario")" class="text-decoration-none text-primary">
                        <i class="fas fa-list me-2"></i>Ver mis comprobantes subidos
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('archivo').addEventListener('change', function(e) {
            const file = e.target.files[0];
            const preview = document.getElementById('archivoPreview');
            const previewContent = document.getElementById('previewContent');
            
            if (file) {
                preview.classList.remove('d-none');
                
                if (file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        previewContent.innerHTML = `
                            <img src="${e.target.result}" alt="Vista previa" class="mb-2" />
                            <p class="mb-0 text-muted"><strong>${file.name}</strong></p>
                            <p class="mb-0 text-muted small">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                        `;
                    };
                    reader.readAsDataURL(file);
                } else if (file.type === 'application/pdf') {
                    previewContent.innerHTML = `
                        <i class="fas fa-file-pdf fa-4x text-danger mb-2"></i>
                        <p class="mb-0 text-muted"><strong>${file.name}</strong></p>
                        <p class="mb-0 text-muted small">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                    `;
                } else {
                    previewContent.innerHTML = `
                        <i class="fas fa-file fa-4x text-secondary mb-2"></i>
                        <p class="mb-0 text-muted"><strong>${file.name}</strong></p>
                        <p class="mb-0 text-muted small">${(file.size / 1024 / 1024).toFixed(2)} MB</p>
                    `;
                }
            } else {
                preview.classList.add('d-none');
            }
        });
    </script>
}

