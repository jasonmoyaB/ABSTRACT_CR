@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Gestión de Usuarios";
}

@Html.AntiForgeryToken()

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 mb-0">Gestión de Usuarios</h1>
                <div class="text-muted">
                    <i class="fas fa-users me-2"></i>
                    Administración del Sistema
                </div>
            </div>
        </div>
    </div>

    <!-- Estadísticas Rápidas -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@((ViewBag.Usuarios as List<Usuario>)?.Count ?? 0)</h4>
                            <p class="card-text">Total Usuarios</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-users fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mt-3 mt-md-0">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@((ViewBag.Usuarios as List<Usuario>)?.Count(u => u.Activo) ?? 0)</h4>
                            <p class="card-text">Usuarios Activos</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-user-check fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mt-3 mt-md-0">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@((ViewBag.Usuarios as List<Usuario>)?.Count(u => !u.Activo) ?? 0)</h4>
                            <p class="card-text">Usuarios Inactivos</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-user-times fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mt-3 mt-md-0">
            <div class="card bg-info text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">@((ViewBag.EbookActual as EbookEdicion)?.PermitirDescarga == true ? "Habilitado" : "Deshabilitado")</h4>
                            <p class="card-text">Estado del Ebook</p>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-book fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Lista de Usuarios -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-users me-2"></i>
                        Usuarios Registrados
                    </h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <!-- Agregamos id="tabla-usuarios" -->
                        <table id="tabla-usuarios" class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Email</th>
                                    <th>Rol</th>
                                    <th>Fecha Registro</th>
                                    <th>Estado</th>
                                    <th>Acciones</th>
                                    <th class="text-center">Comprobantes</th>
                                    <th class="text-center">Permitir Descarga</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.Usuarios != null && (ViewBag.Usuarios as List<Usuario>).Any())
                                {
                                    @foreach (var usuario in ViewBag.Usuarios as List<Usuario>)
                                    {
                                        <tr>
                                            <td><strong>@usuario.Nombre @usuario.Apellido</strong></td>
                                            <td>@usuario.CorreoElectronico</td>
                                            <td>
                                                <span class="badge bg-primary">
                                                    @(usuario.Rol?.NombreRol ?? "Sin rol")
                                                </span>
                                            </td>
                                            <td>@(usuario.FechaRegistro?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                                            <td>
                                                <span class="badge @(usuario.Activo ? "bg-success" : "bg-danger")" id="estado-badge-@usuario.UsuarioID">
                                                    @(usuario.Activo ? "Activo" : "Inactivo")
                                                </span>
                                            </td>
                                            <td>
                                                <!--Botón para Activar/Desactivar -->
                                                <button class="btn btn-sm @(usuario.Activo ? "btn-outline-danger" : "btn-outline-success") me-1" 
                                                        id="btn-toggle-@usuario.UsuarioID"
                                                        onclick="toggleEstadoUsuario(@usuario.UsuarioID, @(usuario.Activo ? "false" : "true"), '@usuario.Nombre @usuario.Apellido')" 
                                                        title="@(usuario.Activo ? "Desactivar cuenta" : "Activar cuenta")">
                                                    <i class="fas @(usuario.Activo ? "fa-ban" : "fa-check-circle")"></i>
                                                    @(usuario.Activo ? "Desactivar" : "Activar")
                                                </button>
                                                
                                                <!-- Botón Extender Suscripción -->
                                                <button class="btn btn-sm btn-outline-success" 
                                                        onclick="extenderSuscripcion(@usuario.UsuarioID, '@usuario.Nombre @usuario.Apellido', this)" 
                                                        title="Extender suscripción un mes">
                                                    <i class="fas fa-calendar-plus"></i> Extender
                                                </button>

                                                <!-- Botón Cambiar Rol -->
                                                <button class="btn btn-sm btn-outline-primary btn-cambiar-rol"
                                                        data-usuario-id="@usuario.UsuarioID"
                                                        data-usuario-nombre="@usuario.Nombre @usuario.Apellido"
                                                        data-rol-id="@(usuario.RolID ?? 0)"
                                                        title="Cambiar rol del usuario">
                                                    <i class="fas fa-user-shield"></i> Rol
                                                </button>
                                            </td>
                                            <td class="text-center">
                                                <button class="btn btn-sm btn-outline-info" onclick="verComprobantes(@usuario.UsuarioID, '@usuario.Nombre @usuario.Apellido')" title="Ver comprobantes de pago">
                                                    <i class="fas fa-receipt"></i> Ver
                                                </button>
                                            </td>
                                            <td class="text-center">
                                                <div class="form-check form-switch d-inline-block">
                                                    <input class="form-check-input toggle-usuario-descarga"
                                                           type="checkbox"
                                                           data-usuario-id="@usuario.UsuarioID"
                                                           @(usuario.PermitirDescargaEbook ? "checked" : "")>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center text-muted">No hay usuarios registrados</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div><!-- /.table-responsive -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Comprobantes -->
<div class="modal fade" id="comprobantesModal" tabindex="-1" aria-labelledby="comprobantesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="comprobantesModalLabel">
                    <i class="fas fa-receipt me-2"></i>Comprobantes de Pago
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="comprobantesModalBody">
                <!-- El contenido se carga dinámicamente -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Cambiar Rol -->
<div class="modal fade" id="modalCambiarRol" tabindex="-1" aria-labelledby="modalCambiarRolLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalCambiarRolLabel">
                    <i class="fas fa-user-shield me-2"></i>Cambiar Rol
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="cambiarRol_UsuarioId" />
                <p class="mb-3">Usuario: <strong id="cambiarRol_NombreUsuario"></strong></p>
                <div class="mb-3">
                    <label for="cambiarRol_Select" class="form-label fw-bold">Nuevo Rol</label>
                    <select id="cambiarRol_Select" class="form-select">
                        @if (ViewBag.Roles != null)
                        {
                            @foreach (var r in ViewBag.Roles as List<Rol>)
                            {
                                <option value="@r.RolID">@r.NombreRol</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnConfirmarCambiarRol">
                    <i class="fas fa-save me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- SweetAlert2 para Alertas Visuales -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Inicializar DataTable cuando el DOM y los scripts globales estén listos
        $(document).ready(function () {
            console.log("Inicializando DataTable en Gestión de Usuarios...");

            $('#tabla-usuarios').DataTable({
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50],
                order: [], // sin orden inicial forzado
                columnDefs: [
                    // "Acciones" (col 5), "Comprobantes" (col 6) y "Permitir Descarga" (col 7) no ordenables
                    { orderable: false, targets: [5, 6, 7] }
                ],
                language: {
                    decimal: ",",
                    thousands: ".",
                    lengthMenu: "Mostrar _MENU_ registros",
                    zeroRecords: "No se encontraron resultados",
                    info: "Mostrando _START_ a _END_ de _TOTAL_ usuarios",
                    infoEmpty: "Mostrando 0 a 0 de 0 usuarios",
                    infoFiltered: "(filtrado de _MAX_ en total)",
                    search: "Buscar:",
                    paginate: {
                        first: "Primero",
                        last: "Último",
                        next: "Siguiente",
                        previous: "Anterior"
                    }
                }
            });

            console.log("DataTable inicializado ✅");

            // Configurar los toggles de descarga después de inicializar la tabla
            configurarTogglesDescarga();
        });

        // NUEVA FUNCIÓN: Toggle Estado de Usuario (Activar/Desactivar)
        function toggleEstadoUsuario(usuarioId, activar, nombreUsuario) {
            const accion = activar ? 'activar' : 'desactivar';
            
            if (!confirm(`¿Estás seguro de que deseas ${accion} la cuenta de "${nombreUsuario}"?`)) {
                return;
            }

            // Obtener el token anti-forgery
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            // Deshabilitar el botón mientras se procesa
            const boton = document.getElementById(`btn-toggle-${usuarioId}`);
            const htmlOriginal = boton.innerHTML;
            boton.disabled = true;
            boton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

            // FormData para POST
            const formData = new FormData();
            formData.append('usuarioId', usuarioId);
            formData.append('activar', activar);
            formData.append('__RequestVerificationToken', token);

            fetch('@Url.Action("CambiarEstadoUsuario", "Usuario")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    mostrarMensaje('success', data.message);
                    
                    // Actualizar el badge de estado
                    const badge = document.getElementById(`estado-badge-${usuarioId}`);
                    if (data.nuevoEstado) {
                        badge.className = 'badge bg-success';
                        badge.textContent = 'Activo';
                        
                        // Actualizar el botón
                        boton.className = 'btn btn-sm btn-outline-danger me-1';
                        boton.title = 'Desactivar cuenta';
                        boton.innerHTML = '<i class="fas fa-ban"></i> Desactivar';
                        boton.setAttribute('onclick', `toggleEstadoUsuario(${usuarioId}, false, '${nombreUsuario}')`);
                    } else {
                        badge.className = 'badge bg-danger';
                        badge.textContent = 'Inactivo';
                        
                        // Actualizar el botón
                        boton.className = 'btn btn-sm btn-outline-success me-1';
                        boton.title = 'Activar cuenta';
                        boton.innerHTML = '<i class="fas fa-check-circle"></i> Activar';
                        boton.setAttribute('onclick', `toggleEstadoUsuario(${usuarioId}, true, '${nombreUsuario}')`);
                    }
                    
                    // Actualizar los contadores de las tarjetas superiores
                    setTimeout(() => location.reload(), 1500);
                } else {
                    mostrarMensaje('error', data.message);
                    boton.innerHTML = htmlOriginal;
                }
            })
            .catch(error => {
                console.error('Error al cambiar estado:', error);
                mostrarMensaje('error', 'Error al cambiar el estado del usuario');
                boton.innerHTML = htmlOriginal;
            })
            .finally(() => {
                boton.disabled = false;
            });
        }

        // Separamos la lógica de toggles en una función para poder llamarla
        function configurarTogglesDescarga() {
            console.log('Configurando toggles de permitir descarga...');

            const toggles = document.querySelectorAll('.toggle-usuario-descarga');
            console.log(`Encontrados ${toggles.length} toggles`);

            toggles.forEach(function (toggle) {
                toggle.addEventListener('change', function () {
                    console.log('Toggle cambiado:', this);

                    const checkbox = this;
                    const usuarioId = checkbox.getAttribute('data-usuario-id');
                    const permitirDescarga = checkbox.checked;

                    console.log(`UsuarioID: ${usuarioId}, PermitirDescarga: ${permitirDescarga}`);

                    // Deshabilitar el toggle mientras se procesa
                    checkbox.disabled = true;

                    // Obtener el token anti-forgery
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    console.log('Token anti-forgery:', token ? 'Encontrado' : 'No encontrado');

                    // FormData para POST
                    const formData = new FormData();
                    formData.append('usuarioId', usuarioId);
                    formData.append('permitirDescarga', permitirDescarga);
                    formData.append('__RequestVerificationToken', token);

                    fetch('@Url.Action("ToggleUsuarioDescarga", "Usuarios")', {
                        method: 'POST',
                        body: formData
                    })
                        .then(response => {
                            console.log('Respuesta recibida:', response.status);
                            return response.json();
                        })
                        .then(data => {
                            console.log('Datos recibidos:', data);
                            if (data.success) {
                                mostrarMensaje('success', data.message);
                            } else {
                                mostrarMensaje('error', data.message);
                                // Revertir el toggle si hay error
                                checkbox.checked = !permitirDescarga;
                            }
                        })
                        .catch(error => {
                            console.error('Error en la petición:', error);
                            mostrarMensaje('error', 'Error al actualizar la configuración del usuario');
                            // Revertir el toggle si hay error
                            checkbox.checked = !permitirDescarga;
                        })
                        .finally(() => {
                            // Rehabilitar el toggle
                            checkbox.disabled = false;
                        });
                });
            });
        }

        function extenderSuscripcion(usuarioId, nombreUsuario, btnElement) {
            Swal.fire({
                title: '¿Extender suscripción?',
                html: `Estás a punto de agregar <b>30 días exactos</b> al plan de <b>${nombreUsuario}</b>.`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-check"></i> Sí, extender un mes',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    // Obtener el token anti-forgery
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    // FormData para POST
                    const formData = new FormData();
                    formData.append('usuarioId', usuarioId);
                    formData.append('__RequestVerificationToken', token);

                    // Deshabilitar el botón mientras se procesa
                    const boton = btnElement;
                    const textoOriginal = boton.innerHTML;
                    boton.disabled = true;
                    boton.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Procesando...';

                    fetch('@Url.Action("ExtenderSuscripcion", "Usuarios")', {
                        method: 'POST',
                        body: formData
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                mostrarMensaje('success', data.message);
                                Swal.fire('¡Éxito!', data.message, 'success');
                            } else {
                                mostrarMensaje('error', data.message);
                                Swal.fire('Error', data.message, 'error');
                            }
                        })
                        .catch(error => {
                            console.error('Error en la petición:', error);
                            mostrarMensaje('error', 'Error al extender la suscripción');
                        })
                        .finally(() => {
                            // Rehabilitar el botón
                            boton.disabled = false;
                            boton.innerHTML = textoOriginal;
                        });
                }
            });
        }

        // ---- Cambiar Rol ----
        $(document).on('click', '.btn-cambiar-rol', function () {
            const btn = $(this);
            $('#cambiarRol_UsuarioId').val(btn.data('usuario-id'));
            $('#cambiarRol_NombreUsuario').text(btn.data('usuario-nombre'));
            $('#cambiarRol_Select').val(btn.data('rol-id'));
            new bootstrap.Modal(document.getElementById('modalCambiarRol')).show();
        });

        $(document).on('click', '#btnConfirmarCambiarRol', function () {
            const btn = $(this);
            const usuarioId = $('#cambiarRol_UsuarioId').val();
            const rolId = $('#cambiarRol_Select').val();
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i> Guardando...');

            const formData = new FormData();
            formData.append('usuarioId', usuarioId);
            formData.append('rolId', rolId);
            formData.append('__RequestVerificationToken', token);

            fetch('@Url.Action("CambiarRol", "Usuarios")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    mostrarMensaje('success', data.message);
                    setTimeout(() => location.reload(), 1200);
                } else {
                    mostrarMensaje('error', data.message);
                }
            })
            .catch(error => {
                console.error('Error al cambiar rol:', error);
                mostrarMensaje('error', 'Error al cambiar el rol del usuario');
            })
            .finally(() => {
                btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> Guardar');
                bootstrap.Modal.getInstance(document.getElementById('modalCambiarRol')).hide();
            });
        });

        function mostrarMensaje(tipo, mensaje) {
            console.log(`Mostrando mensaje ${tipo}:`, mensaje);

            const alertClass = tipo === 'success'
                ? 'alert-success'
                : tipo === 'error'
                    ? 'alert-danger'
                    : 'alert-info';

            const icon = tipo === 'success'
                ? 'fa-check-circle'
                : tipo === 'error'
                    ? 'fa-exclamation-circle'
                    : 'fa-info-circle';

            const alertHtml = `
                <div class="alert ${alertClass} alert-dismissible fade show" role="alert">
                    <i class="fas ${icon} me-2"></i>
                    ${mensaje}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;

            const container = document.querySelector('.container-fluid');
            container.insertAdjacentHTML('afterbegin', alertHtml);

            setTimeout(function () {
                const alert = container.querySelector('.alert');
                if (alert) {
                    alert.remove();
                }
            }, 5000);
        }

        function verComprobantes(usuarioId, nombreUsuario) {
            // Limpiar el contenido del modal
            $('#comprobantesModalBody').html('<div class="text-center py-4"><i class="fas fa-spinner fa-spin fa-2x text-primary"></i><p class="mt-2">Cargando comprobantes...</p></div>');
            
            // Actualizar el título del modal
            $('#comprobantesModalLabel').text('Comprobantes de Pago - ' + nombreUsuario);
            
            // Mostrar el modal
            $('#comprobantesModal').modal('show');
            
            // Obtener el token anti-forgery
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            // Cargar los comprobantes del usuario
            fetch('@Url.Action("ObtenerComprobantesUsuario", "Usuarios")?usuarioId=' + usuarioId, {
                method: 'GET',
                headers: {
                    'RequestVerificationToken': token
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    mostrarComprobantes(data.comprobantes, nombreUsuario);
                } else {
                    $('#comprobantesModalBody').html(`
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            ${data.message || 'No se pudieron cargar los comprobantes'}
                        </div>
                    `);
                }
            })
            .catch(error => {
                console.error('Error al cargar comprobantes:', error);
                $('#comprobantesModalBody').html(`
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        Error al cargar los comprobantes. Por favor, intenta nuevamente.
                    </div>
                `);
            });
        }

        function mostrarComprobantes(comprobantes, nombreUsuario) {
            if (!comprobantes || comprobantes.length === 0) {
                $('#comprobantesModalBody').html(`
                    <div class="text-center py-5">
                        <i class="fas fa-inbox fa-3x text-muted mb-3 opacity-50"></i>
                        <h5 class="text-muted">No hay comprobantes</h5>
                        <p class="text-muted">${nombreUsuario} aún no ha subido ningún comprobante de pago.</p>
                    </div>
                `);
                return;
            }

            let html = '<div class="table-responsive"><table class="table table-hover align-middle">';
            html += '<thead class="table-light"><tr>';
            html += '<th>Archivo</th><th>Fecha de Subida</th><th>Estado</th><th>Observaciones</th><th>Acciones</th>';
            html += '</tr></thead><tbody>';

            comprobantes.forEach(function(comp) {
                const estadoBadge = comp.estado === 'Aprobado' 
                    ? '<span class="badge bg-success">Aprobado</span>'
                    : comp.estado === 'Rechazado'
                    ? '<span class="badge bg-danger">Rechazado</span>'
                    : '<span class="badge" style="background: linear-gradient(135deg, #007FFF 0%, #00BFFF 100%); color: white;">Pendiente</span>';

                const iconoArchivo = comp.tipoArchivo === '.pdf'
                    ? '<i class="fas fa-file-pdf text-danger"></i>'
                    : '<i class="fas fa-file-image text-primary"></i>';

                // Botones de cambio de estado (solo si está pendiente)
                let botonesEstado = '';
                if (comp.estado === 'Pendiente') {
                    botonesEstado = `
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-success" onclick="cambiarEstadoComprobante(${comp.comprobanteID}, 'Aprobado', ${comp.usuarioId})" title="Aprobar">
                                <i class="fas fa-check"></i> Aprobar
                            </button>
                            <button type="button" class="btn btn-danger" onclick="cambiarEstadoComprobante(${comp.comprobanteID}, 'Rechazado', ${comp.usuarioId})" title="Rechazar">
                                <i class="fas fa-times"></i> Rechazar
                            </button>
                        </div>
                    `;
                } else {
                    botonesEstado = `<small class="text-muted">Estado finalizado</small>`;
                }

                html += '<tr id="comprobante-row-' + comp.comprobanteID + '">';
                html += `<td>${iconoArchivo} <strong>${comp.nombreArchivoOriginal || 'Comprobante'}</strong></td>`;
                html += `<td>${new Date(comp.fechaSubida).toLocaleDateString('es-ES', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' })}</td>`;
                html += `<td id="estado-badge-${comp.comprobanteID}">${estadoBadge}</td>`;
                html += `<td><small class="text-muted">${comp.observaciones || 'Sin observaciones'}</small></td>`;
                html += `<td>
                    <div class="d-flex gap-2 align-items-center">
                        <a href="${comp.rutaArchivo}" target="_blank" class="btn btn-sm btn-outline-primary" title="Ver">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a href="${comp.rutaArchivo}" download class="btn btn-sm btn-outline-secondary" title="Descargar">
                            <i class="fas fa-download"></i>
                        </a>
                        <div class="ms-2">
                            ${botonesEstado}
                        </div>
                    </div>
                </td>`;
                html += '</tr>';
            });

            html += '</tbody></table></div>';
            $('#comprobantesModalBody').html(html);
        }

        function cambiarEstadoComprobante(comprobanteId, nuevoEstado, usuarioId) {
            if (!confirm(`¿Estás seguro de cambiar el estado del comprobante a "${nuevoEstado}"?`)) {
                return;
            }

            // Obtener el token anti-forgery
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            // FormData para POST
            const formData = new FormData();
            formData.append('comprobanteId', comprobanteId);
            formData.append('nuevoEstado', nuevoEstado);
            formData.append('__RequestVerificationToken', token);

            // Deshabilitar botones mientras se procesa
            const botones = event.target.closest('.btn-group').querySelectorAll('button');
            botones.forEach(btn => btn.disabled = true);

            fetch('@Url.Action("CambiarEstadoComprobante", "Usuarios")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    mostrarMensaje('success', data.message);
                    
                    // Actualizar el badge de estado
                    const estadoBadge = nuevoEstado === 'Aprobado' 
                        ? '<span class="badge bg-success">Aprobado</span>'
                        : '<span class="badge bg-danger">Rechazado</span>';
                    
                    $('#estado-badge-' + comprobanteId).html(estadoBadge);
                    
                    // Remover los botones de acción
                    const row = $('#comprobante-row-' + comprobanteId);
                    const accionesCell = row.find('td:last-child');
                    accionesCell.find('.btn-group').replaceWith('<small class="text-muted">Estado finalizado</small>');
                } else {
                    mostrarMensaje('error', data.message);
                    // Rehabilitar botones
                    botones.forEach(btn => btn.disabled = false);
                }
            })
            .catch(error => {
                console.error('Error al cambiar estado:', error);
                mostrarMensaje('error', 'Error al cambiar el estado del comprobante');
                // Rehabilitar botones
                botones.forEach(btn => btn.disabled = false);
            });
        }
    </script>
}
